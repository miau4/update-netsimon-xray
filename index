<script>
    // =============================================================================
    // NEON CANVAS
    // Correção GPUAUX/MALI: loop pausável via visibilitychange e bridge Android
    // =============================================================================
    (function() {
        var canvas = document.getElementById('neon-canvas');
        var ctx = canvas.getContext('2d');
        var COLORS = ['rgba(0,123,255,','rgba(111,0,255,','rgba(255,0,200,','rgba(0,255,180,','rgba(0,220,255,','rgba(255,60,120,','rgba(255,160,0,','rgba(80,255,80,'];
        var lines = [], NUM_LINES = 12, TRAIL_LEN = 120;
        var _rafId = null;   // ID do requestAnimationFrame ativo
        var _running = true; // flag de estado do loop

        function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
        function createLine() {
            var w = canvas.width || window.innerWidth, h = canvas.height || window.innerHeight;
            var angle = Math.random() * Math.PI * 2, speed = 0.8 + Math.random() * 2.2;
            var color = COLORS[Math.floor(Math.random() * COLORS.length)];
            var alpha = 0.35 + Math.random() * 0.55, width = 1.2 + Math.random() * 3, glow = 6 + Math.random() * 22;
            var side = Math.floor(Math.random() * 4), extra = TRAIL_LEN * speed, x, y;
            if (side===0){x=Math.random()*w;y=-extra;}else if(side===1){x=w+extra;y=Math.random()*h;}else if(side===2){x=Math.random()*w;y=h+extra;}else{x=-extra;y=Math.random()*h;}
            return { x: x, y: y, vx: Math.cos(angle)*speed, vy: Math.sin(angle)*speed, color: color, alpha: alpha, width: width, glow: glow, age:0, maxAge:300+Math.random()*400, trail:[] };
        }
        function init() { lines = []; for(var i=0;i<NUM_LINES;i++){var l=createLine();l.age=Math.random()*l.maxAge;lines.push(l);} }
        function draw() {
            if (!_running) { _rafId = null; return; } // para o loop se pausado
            ctx.clearRect(0,0,canvas.width,canvas.height);
            for(var i=0;i<lines.length;i++){
                var l=lines[i];l.x+=l.vx;l.y+=l.vy;l.age++;
                l.trail.push({x:l.x,y:l.y});if(l.trail.length>TRAIL_LEN)l.trail.shift();
                var lr=l.age/l.maxAge,ff=lr<0.12?lr/0.12:lr>0.78?1-(lr-0.78)/0.22:1,ca=l.alpha*ff;
                if(l.trail.length>=2){
                    var t0=l.trail[0],tN=l.trail[l.trail.length-1];
                    var g=ctx.createLinearGradient(t0.x,t0.y,tN.x,tN.y);
                    g.addColorStop(0,l.color+'0)');g.addColorStop(0.4,l.color+(ca*0.3).toFixed(2)+')');g.addColorStop(1,l.color+ca.toFixed(2)+')');
                    ctx.save();ctx.shadowColor=l.color+ca.toFixed(2)+')';ctx.shadowBlur=l.glow;ctx.strokeStyle=g;ctx.lineWidth=l.width;ctx.lineCap='round';ctx.lineJoin='round';
                    ctx.beginPath();ctx.moveTo(l.trail[0].x,l.trail[0].y);
                    for(var j=1;j<l.trail.length;j++)ctx.lineTo(l.trail[j].x,l.trail[j].y);
                    ctx.stroke();
                    ctx.shadowBlur=l.glow*2.5;ctx.strokeStyle=l.color+Math.min(1,ca*1.6).toFixed(2)+')';ctx.lineWidth=l.width*0.45;
                    var last=l.trail.length-1;
                    ctx.beginPath();ctx.moveTo(l.trail[Math.max(0,last-8)].x,l.trail[Math.max(0,last-8)].y);ctx.lineTo(l.trail[last].x,l.trail[last].y);ctx.stroke();
                    ctx.restore();
                }
                var margin=TRAIL_LEN*(Math.abs(l.vx)+Math.abs(l.vy));
                if(l.age>=l.maxAge||l.x<-margin||l.x>canvas.width+margin||l.y<-margin||l.y>canvas.height+margin)lines[i]=createLine();
            }
            _rafId = requestAnimationFrame(draw);
        }

        // Pausa o loop e cancela o RAF pendente
        function pauseCanvas() {
            _running = false;
            if (_rafId !== null) { cancelAnimationFrame(_rafId); _rafId = null; }
        }

        // Retoma o loop apenas se estava parado
        function resumeCanvas() {
            if (!_running) { _running = true; draw(); }
        }

        // Page Visibility API — pausa quando o app vai ao background
        document.addEventListener('visibilitychange', function() {
            if (document.hidden) pauseCanvas(); else resumeCanvas();
        });

        // Bridge para o Kotlin chamar via evaluateJavascript em onPause/onResume
        window.onWebViewPause  = pauseCanvas;
        window.onWebViewResume = resumeCanvas;

        window.addEventListener('resize',resize);
        resize(); init(); draw();
    })();

    // =============================================================================
    // Storage
    // =============================================================================
    function storageSave(k,v){if(window.Android&&Android.storageSave)Android.storageSave(k,v);else try{localStorage.setItem(k,v);}catch(e){}}
    function storageGet(k){if(window.Android&&Android.storageGet)return Android.storageGet(k);try{return localStorage.getItem(k);}catch(e){return null;}}

    // =============================================================================
    // Estado global
    // =============================================================================
    var isConnected=false, isSshConnecting=false;
    var timerInterval=null, connectTime=null, pingFallbackTimer=null;
    var uuidPattern=/^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$/;
    var allOperators=[], currentCategory=null, selectedOpName=null;
    var sshPopupMode='connect', sshPendingOperator=null;

    // =============================================================================
    // Back handler Android
    // =============================================================================
    window.handleAndroidBack = function() {
        if (document.getElementById('log-modal').classList.contains('open')) { closeLogModal(); return; }
        if (document.getElementById('ssh-popup-overlay').classList.contains('open')) { closeSshPopup(); return; }
        if (document.getElementById('operator-modal').classList.contains('open')) { closeOperatorModal(); return; }
        var active = document.querySelector('section.active');
        if (active && active.id !== 'home') { showPage('home'); return; }
    };

    // =============================================================================
    // Init
    // =============================================================================
    window.addEventListener('load', function() {
        var savedUuid = storageGet('netsmon_uuid');
        if (savedUuid) document.getElementById('user-uuid').value = savedUuid;
        var savedConfig = storageGet('netsmon_config');
        if (savedConfig) document.getElementById('config-input').value = savedConfig;
        var savedOp = storageGet('netsmon_operator');
        if (savedOp) selectedOpName = savedOp;
        updateSshCredBtn();

        var BG_DEFAULT = 'https://i.pinimg.com/736x/72/a6/b4/72a6b495e2ed0aed7e883300ad3eb960.jpg';
        var bgUrl = storageGet('netsmon_bg') || BG_DEFAULT;
        if (document.getElementById('gif-url-input')) document.getElementById('gif-url-input').value = bgUrl;

        applyBackgroundLocal();

        if (window.Android && Android.getLocalIp) {
            var localIp = Android.getLocalIp();
            if (localIp) { document.getElementById('ip-display').textContent = localIp; document.getElementById('ping-display').textContent = 'local'; }
        }

        if (window.Android && Android.getOperators) {
            try {
                var json = Android.getOperators();
                if (json && json !== '[]') { var ops = JSON.parse(json); if (ops.length > 0) onOperatorsReady(ops, selectedOpName || ops[0].name); }
            } catch(e) {}
        }
    });

    // =============================================================================
    // Fundo
    // =============================================================================
    function applyBackgroundLocal() {
        var bg = document.getElementById('bg-layer');
        var cached = storageGet('netsmon_bg_cache');
        if (cached && cached.length > 100) {
            bg.style.backgroundImage = "url('" + cached + "')";
            bg.classList.add('loaded');
            return;
        }
        var localImg = new Image();
        localImg.onload = function() {
            bg.style.backgroundImage = "url('file:///android_asset/fundo.png')";
            bg.classList.add('loaded');
        };
        localImg.onerror = function() {};
        localImg.src = 'file:///android_asset/fundo.png';
    }

    function applyBackgroundOnline(url) {
        if (!url || !url.trim()) return;
        url = url.trim();
        var bg = document.getElementById('bg-layer');
        var oldV = document.getElementById('bg-video'); if (oldV) oldV.remove();

        if (/\.(mp4|webm|ogg)(\?.*)?$/i.test(url)) {
            bg.style.backgroundImage = 'none'; bg.classList.remove('loaded');
            var v = document.createElement('video');
            v.id='bg-video'; v.src=url; v.autoplay=true; v.loop=true; v.muted=true; v.playsInline=true;
            v.style.cssText='position:fixed;inset:0;z-index:2;width:100%;height:100%;object-fit:cover;opacity:0;pointer-events:none;transition:opacity 0.8s';
            document.body.insertBefore(v, document.body.firstChild);
            v.oncanplay = function(){ v.style.opacity='0.5'; };
        }
    }

    function applyBackground(url) {
        var oldV = document.getElementById('bg-video'); if (oldV) oldV.remove();
        if (!url || !url.trim()) { applyBackgroundLocal(); return; }
        applyBackgroundLocal();
        applyBackgroundOnline(url.trim());
    }

    // =============================================================================
    // IP local
    // =============================================================================
    window.onLocalIp = function(ip) {
        if (ip) {
            document.getElementById('ip-display').textContent = ip;
            if (!isConnected) document.getElementById('ping-display').textContent = 'local';
        }
    };

    // =============================================================================
    // CREDENCIAIS SSH
    // =============================================================================
    function hasSshCreds() { var u=storageGet('ssh_username'),p=storageGet('ssh_password'); return !!(u&&u.trim()&&p&&p.trim()); }
    function updateSshCredBtn() { var b=document.getElementById('ssh-cred-btn'); if(hasSshCreds())b.classList.add('has-creds');else b.classList.remove('has-creds'); }

    function openSshPopup(editMode, uuid, opName) {
        sshPopupMode = editMode ? 'edit' : 'connect';
        sshPendingOperator = opName || null;
        var su = storageGet('ssh_username') || '', sp = storageGet('ssh_password') || '';
        document.getElementById('ssh-username').value = su;
        document.getElementById('ssh-password').value = sp;
        if (editMode) {
            document.getElementById('ssh-popup-title').textContent = 'CREDENCIAIS SSH';
            document.getElementById('ssh-popup-sub').textContent = 'Edite suas credenciais de acesso SSH.';
            document.getElementById('ssh-cancel-btn').textContent = 'FECHAR';
            document.querySelector('.ssh-btn-confirm').textContent = 'SALVAR';
        } else {
            document.getElementById('ssh-popup-title').textContent = 'ACESSO SSH NECESSÁRIO';
            document.getElementById('ssh-popup-sub').textContent = 'Insira suas credenciais para conectar via SSH.\nSerão salvas para uso futuro.';
            document.getElementById('ssh-cancel-btn').textContent = 'CANCELAR';
            document.querySelector('.ssh-btn-confirm').textContent = 'SALVAR E CONECTAR';
        }
        document.getElementById('ssh-saved-badge').style.display = hasSshCreds() ? 'flex' : 'none';
        document.getElementById('ssh-error-msg').classList.remove('show');
        document.getElementById('ssh-popup-overlay').classList.add('open');
        setTimeout(function() { if(!su) document.getElementById('ssh-username').focus(); else if(!sp) document.getElementById('ssh-password').focus(); }, 300);
    }

    function closeSshPopup() {
        document.getElementById('ssh-popup-overlay').classList.remove('open');
        document.getElementById('ssh-password').type = 'password';
        document.getElementById('pwd-toggle-btn').textContent = '👁';
    }

    function cancelSshPopup() { closeSshPopup(); }

    function togglePwd() {
        var f = document.getElementById('ssh-password'), b = document.getElementById('pwd-toggle-btn');
        if (f.type === 'password') { f.type = 'text'; b.textContent = '🙈'; } else { f.type = 'password'; b.textContent = '👁'; }
    }

    function handleSshOverlayClick(e) { if (e.target === document.getElementById('ssh-popup-overlay')) closeSshPopup(); }

    function confirmSshCredentials() {
        var u = document.getElementById('ssh-username').value.trim();
        var p = document.getElementById('ssh-password').value;
        if (!u || !p) { document.getElementById('ssh-error-msg').classList.add('show'); return; }
        document.getElementById('ssh-error-msg').classList.remove('show');
        storageSave('ssh_username', u);
        storageSave('ssh_password', p);
        updateSshCredBtn();
        closeSshPopup();
        if (sshPopupMode === 'connect' && sshPendingOperator && window.Android && Android.startSshWithCredentials) {
            var btn = document.getElementById('btn-connection'), sl = document.getElementById('status-label');
            isSshConnecting = true;
            btn.classList.add('connecting'); btn.classList.remove('active');
            btn.innerText = 'CANCELAR';
            sl.innerText = 'CONECTANDO...'; sl.classList.add('warn-text'); sl.classList.remove('error-text','connected');
            Android.startSshWithCredentials(sshPendingOperator, u, p);
        }
        sshPendingOperator = null;
    }

    // =============================================================================
    // CheckUser
    // =============================================================================
    var cuRefreshCooldown = false;

    window.onCheckUserLoading = function() {
        var card = document.getElementById('user-info-card');
        card.classList.add('show');
        document.getElementById('cu-loading').style.display = 'flex';
        document.getElementById('cu-grid').style.display = 'none';
        document.getElementById('cu-error').style.display = 'none';
        document.getElementById('cu-refresh-btn').classList.add('spinning');
    };

    window.onCheckUserResult = function(data) {
        var card = document.getElementById('user-info-card');
        var btn  = document.getElementById('cu-refresh-btn');
        btn.classList.remove('spinning');

        if (!data) { card.classList.remove('show'); return; }

        card.classList.add('show');
        document.getElementById('cu-loading').style.display = 'none';

        if (data.error) {
            document.getElementById('cu-grid').style.display = 'none';
            var errEl = document.getElementById('cu-error');
            errEl.style.display = 'block';
            errEl.textContent = '⚠ ' + data.error;
            return;
        }

        document.getElementById('cu-error').style.display = 'none';
        document.getElementById('cu-grid').style.display = 'grid';

        var userEl = document.getElementById('cu-username');
        userEl.textContent = data.username || '--';
        userEl.className = 'cu-item-value';

        var expiryEl = document.getElementById('cu-expiry');
        expiryEl.textContent = data.expiryDate !== '?' ? data.expiryDate : '--';
        expiryEl.className = 'cu-item-value';

        var daysEl = document.getElementById('cu-days');
        var days = data.daysRemaining;
        if (days < 0) { daysEl.textContent='--'; daysEl.className='cu-item-value'; }
        else if (days===0) { daysEl.textContent='EXPIRADO'; daysEl.className='cu-item-value bad'; }
        else if (days<=3) { daysEl.textContent=days+' dia'+(days===1?'':'s'); daysEl.className='cu-item-value bad'; }
        else if (days<=9) { daysEl.textContent=days+' dias'; daysEl.className='cu-item-value warn'; }
        else { daysEl.textContent=days+' dias'; daysEl.className='cu-item-value good'; }

        var connsEl = document.getElementById('cu-conns');
        var active=data.connectionsActive, limit=data.connectionsLimit;
        if (active<0&&limit<0) { connsEl.textContent='--'; connsEl.className='cu-item-value'; }
        else {
            connsEl.textContent=(active>=0?active:'?')+' / '+(limit>=0?limit:'?');
            connsEl.className='cu-item-value'+(active>=0&&limit>=0&&active>=limit?' warn':' good');
        }
    };

    function refreshCheckUser() {
        if (cuRefreshCooldown) return;
        if (!window.Android || !Android.checkUserNow) return;
        cuRefreshCooldown = true;
        setTimeout(function() { cuRefreshCooldown = false; }, 5000);
        Android.checkUserNow();
    }

    // =============================================================================
    // TOAST
    // =============================================================================
    var toastTimer=null;
    function showToast(msg,color,auto){
        var t=document.getElementById('update-toast');
        t.textContent=msg; t.style.borderColor=color||'#2ecc71'; t.style.color=color||'#2ecc71';
        t.classList.add('show');
        if(toastTimer)clearTimeout(toastTimer);
        if(auto!==false)toastTimer=setTimeout(function(){t.classList.remove('show');},3500);
    }

    // =============================================================================
    // Atualizações
    // =============================================================================
    window.onUpdateComplete = function(type){
        if(type==='webview'||type==='all') showToast('🔄 ATUALIZAÇÃO DISPONÍVEL','#4a9eff');
        else showToast('✓ CONFIG ATUALIZADA','#2ecc71');
    };
    window.onUpdateAlreadyUpToDate = function(){ showToast('✓ JÁ ATUALIZADO','#2ecc71'); };

    function checkUpdatesManual(){ if(window.Android&&Android.checkUpdates) Android.checkUpdates(); }

    // =============================================================================
    // Operadoras
    // =============================================================================
    function getModeBadgeClass(mode) {
        switch((mode||'').toUpperCase()){
            case 'SSH_DIRECT': return 'badge-ssh';
            case 'V2RAY':      return 'badge-v2ray';
            case 'SSL_PROXY':  return 'badge-ssl';
            default:           return 'badge-other';
        }
    }
    function getModeBadgeLabel(mode) {
        switch((mode||'').toUpperCase()){
            case 'SSH_DIRECT': return 'SSH';
            case 'V2RAY':      return 'V2RAY';
            case 'SSL_PROXY':  return 'SSL';
            default:           return mode||'?';
        }
    }

    function renderOperators(ops, selName) {
        var cats = [], seen = {};
        ops.forEach(function(o){ var c=o.category&&o.category.name?o.category.name:'Geral'; if(!seen[c]){seen[c]=true;cats.push(c);} });
        var tabsEl = document.getElementById('cat-tabs');
        tabsEl.innerHTML = '';
        if (cats.length > 1) {
            ['Todos'].concat(cats).forEach(function(c){
                var t=document.createElement('button'); t.className='cat-tab'+(currentCategory===c||(!currentCategory&&c==='Todos')?' active':'');
                t.textContent=c; t.onclick=function(){ currentCategory=c==='Todos'?null:c; renderOps(ops,selName); updateCatTabs(); };
                tabsEl.appendChild(t);
            });
        }
        renderOps(ops, selName);
    }

    function updateCatTabs() {
        document.querySelectorAll('.cat-tab').forEach(function(t){
            t.classList.toggle('active', t.textContent===(currentCategory||'Todos'));
        });
    }

    function renderOps(ops, selName) {
        var filtered = currentCategory ? ops.filter(function(o){ return (o.category&&o.category.name?o.category.name:'Geral')===currentCategory; }) : ops;
        var list = document.getElementById('op-list');
        list.innerHTML = '';
        if (!filtered.length) { list.innerHTML='<div style="text-align:center;padding:24px;color:#333;font-size:.8rem">Nenhuma operadora encontrada</div>'; return; }
        filtered.forEach(function(op) {
            var div=document.createElement('div'); div.className='op-item'+(op.name===selName?' selected':'');
            var iconSrc=op.icon||'file:///android_asset/operadora.png';
            div.innerHTML=
                '<img class="op-icon" src="'+iconSrc+'" onerror="this.onerror=null;this.src=\'file:///android_asset/operadora.png\'"/>'+
                '<div class="op-info"><div class="op-name">'+op.name+'</div><div class="op-desc">'+(op.description||'')+'</div></div>'+
                '<span class="op-mode-badge '+getModeBadgeClass(op.mode)+'">'+getModeBadgeLabel(op.mode)+'</span>'+
                '<div class="op-check"></div>';
            div.onclick=function(){ selectOperatorUi(op.name,ops); };
            list.appendChild(div);
        });
    }

    function selectOperatorUi(name, ops) {
        selectedOpName = name;
        storageSave('netsmon_operator', name);
        if (window.Android && Android.selectOperator) Android.selectOperator(name);
        var op = ops.find(function(o){ return o.name===name; });
        if (op) {
            document.getElementById('op-selected-label').textContent = op.name;
            var imgSrc = op.icon || 'file:///android_asset/operadora.png';
            document.getElementById('op-circle-img').src = imgSrc;
            var isSsh = op.mode==='SSH_DIRECT'||op.mode==='SSL_PROXY';
            document.getElementById('uuid-section').classList.toggle('hidden', isSsh);
        }
        renderOps(ops, name);
        setTimeout(closeOperatorModal, 250);
    }

    window.onOperatorsReady = function(ops, defName) {
        allOperators = ops;
        var nameToSel = selectedOpName || defName || (ops.length>0?ops[0].name:'');
        if (nameToSel && !ops.find(function(o){return o.name===nameToSel;})) nameToSel = ops.length>0?ops[0].name:'';
        selectedOpName = nameToSel;
        var op = ops.find(function(o){return o.name===nameToSel;});
        if (op) {
            document.getElementById('op-selected-label').textContent = op.name;
            var imgSrc = op.icon || 'file:///android_asset/operadora.png';
            document.getElementById('op-circle-img').src = imgSrc;
            var isSsh = op.mode==='SSH_DIRECT'||op.mode==='SSL_PROXY';
            document.getElementById('uuid-section').classList.toggle('hidden', isSsh);
        }
        renderOperators(ops, nameToSel);
    };

    function openOperatorModal()  { document.getElementById('operator-modal').classList.add('open'); renderOperators(allOperators,selectedOpName); }
    function closeOperatorModal() { document.getElementById('operator-modal').classList.remove('open'); }
    function handleModalBackdrop(e) { if(e.target===document.getElementById('operator-modal'))closeOperatorModal(); }

    // =============================================================================
    // PING
    // =============================================================================
    window.onPingResult = function(ping, ip) {
        clearTimeout(pingFallbackTimer);
        if (ip) document.getElementById('ip-display').textContent = ip;
        document.getElementById('ping-display').textContent = ping >= 0 ? ping+'ms' : 'timeout';
    };

    function requestPing() {
        if (!isConnected) return;
        document.getElementById('ping-display').textContent = '...';
        if (window.Android && Android.measurePingNow) Android.measurePingNow();
    }

    // =============================================================================
    // TIMER
    // =============================================================================
    function startTimer() {
        connectTime = Date.now();
        clearInterval(timerInterval);
        timerInterval = setInterval(function() {
            var e=Math.floor((Date.now()-connectTime)/1000), h=Math.floor(e/3600), m=Math.floor((e%3600)/60), s=e%60;
            document.getElementById('timer-display').textContent =
                (h<10?'0':'')+h+':'+(m<10?'0':'')+m+':'+(s<10?'0':'')+s;
        }, 1000);
    }
    function stopTimer() { clearInterval(timerInterval); timerInterval=null; document.getElementById('timer-display').textContent='--:--:--'; }

    // =============================================================================
    // Estado do túnel
    // =============================================================================
    window.onTunnelState = function(state) {
        var btn=document.getElementById('btn-connection'), sl=document.getElementById('status-label');
        if (state.running) {
            isConnected=true; isSshConnecting=false;
            btn.classList.add('active'); btn.classList.remove('connecting');
            btn.disabled=false; btn.innerText='PARAR';
            sl.innerText='CONECTADO'; sl.className='status-text connected';
            startTimer();
            pingFallbackTimer=setTimeout(function(){if(document.getElementById('ping-display').textContent==='aguarde...')document.getElementById('ping-display').textContent='--';},6000);
        } else {
            isConnected=false; isSshConnecting=false;
            btn.classList.remove('active','connecting');
            btn.disabled=false; btn.innerText='LIGAR';
            stopTimer();
            document.getElementById('ping-display').textContent='-- ms';
            document.getElementById('ip-display').textContent='--';
            if (state.error) {
                var msg = state.error;
                if (msg==='ssh_auth_failed') msg='CREDENCIAIS INVÁLIDAS';
                else if (msg==='ssh_payload_error') msg='PAYLOAD / CDN FALHOU';
                else if (msg.startsWith('ssh_error:')) msg='ERRO: '+msg.replace('ssh_error:','');
                else if (msg==='permission_denied') msg='PERMISSÃO NEGADA';
                else if (msg==='import_failed') msg='ERRO AO IMPORTAR CONFIG';
                else if (msg==='no_operator_selected') msg='SELECIONE UMA OPERADORA';
                else if (msg==='xray_start_failed') msg='XRAY FALHOU AO INICIAR';
                sl.innerText=msg; sl.className='status-text error-text';
                if (msg==='CREDENCIAIS INVÁLIDAS') {
                    var op=allOperators.find(function(o){return o.name===selectedOpName;});
                    var isSsh=op&&(op.mode==='SSH_DIRECT'||op.mode==='SSL_PROXY');
                    if (isSsh) openSshPopup(false, null, selectedOpName);
                }
            } else {
                sl.innerText=''; sl.className='status-text';
            }
        }
    };

    window.onSshStatus = function(msg) {
        var sl = document.getElementById('status-label');
        sl.innerText = msg; sl.className = 'status-text warn-text';
    };

    window.requestSshCredentials = function(opName, authFailed) {
        if (authFailed) {
            document.getElementById('ssh-error-msg').textContent = 'Credenciais inválidas. Tente novamente.';
            document.getElementById('ssh-error-msg').classList.add('show');
        }
        openSshPopup(false, null, opName);
    };

    // =============================================================================
    // BOTÃO LIGAR / PARAR
    // =============================================================================
    document.getElementById('btn-connection').onclick = function() {
        var btn=document.getElementById('btn-connection'), sl=document.getElementById('status-label');

        if (isSshConnecting) {
            if (window.Android) Android.stopTunnel();
            else resetConnectionBtn();
            return;
        }

        if (btn.innerText === 'LIGAR') {
            var op = allOperators.find(function(o){ return o.name === selectedOpName; });
            var isSsh = op && (op.mode === 'SSH_DIRECT' || op.mode === 'SSL_PROXY');

            if (isSsh) {
                if (!hasSshCreds()) {
                    openSshPopup(false, null, selectedOpName);
                    return;
                }
                isSshConnecting = true;
                btn.classList.add('connecting'); btn.classList.remove('active');
                btn.innerText = 'CANCELAR';
                sl.innerText = 'CONECTANDO...'; sl.classList.add('warn-text'); sl.classList.remove('error-text','connected');
                document.getElementById('ping-display').textContent = 'aguarde...';

                if (window.Android) {
                    var sshUser = storageGet('ssh_username') || '';
                    var sshPass = storageGet('ssh_password') || '';
                    Android.startSshWithCredentials(selectedOpName, sshUser, sshPass);
                }

            } else {
                var uuid = document.getElementById('user-uuid').value.trim();
                if (!uuid) { alert('Insira sua CHAVE DE ACESSO (UUID)!'); return; }
                if (!uuidPattern.test(uuid)) { alert('UUID inválido.\nFormato: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'); return; }
                storageSave('netsmon_uuid', uuid);

                if (!selectedOpName && window.Android) {
                    if (!confirm('Nenhuma operadora selecionada. Usar configuração padrão?')) return;
                }

                btn.disabled = true;
                sl.innerText = 'CONECTANDO...'; sl.classList.add('connected'); sl.classList.remove('error-text');
                document.getElementById('ping-display').textContent = 'aguarde...';

                if (window.Android) {
                    var sshUser = storageGet('ssh_username') || '';
                    var sshPass = storageGet('ssh_password') || '';
                    Android.startTunnelWithCreds(uuid, sshUser, sshPass);
                } else {
                    setTimeout(function(){ window.onTunnelState({running:true,error:null}); }, 1200);
                }
            }

        } else if (btn.innerText === 'PARAR') {
            btn.disabled = true;
            if (window.Android) Android.stopTunnel();
            else window.onTunnelState({running:false,error:null});
        }
    };

    // =============================================================================
    // AppLog — Log de conexão (estilo HTTP Injector)
    //
    // Cada entrada tem o formato: "HH:mm:ss|emoji|mensagem"
    // Mapeamos o emoji para uma classe CSS de cor.
    // =============================================================================
    var alAutoScroll = true;
    var alCount = 0;

    var ICON_CLASS = {
        '🔗': 'al-connect',
        '🔴': 'al-disconnect',
        '✅': 'al-success',
        '❌': 'al-error',
        '⚠️': 'al-warn',
        '📶': 'al-ping',
        '🌐': 'al-ip',
        '👤': 'al-user',
        '🔄': 'al-update',
        'ℹ️': 'al-info',
        '♻️': 'al-reconnect'
    };

    /**
     * Constrói e appenda um elemento DOM para uma entrada do AppLog.
     * @param {string} raw  — string no formato "HH:mm:ss|emoji|mensagem"
     */
    function appendAlEntry(raw) {
        var el = document.getElementById('log-content');
        if (!el) return;

        // Remove estado vazio se presente
        var empty = el.querySelector('.log-empty');
        if (empty) empty.remove();

        var parts = raw.split('|');
        var time  = parts[0] || '';
        var icon  = parts[1] || '';
        // Mensagem pode conter | — junta o restante
        var msg   = parts.slice(2).join('|');

        var cls = ICON_CLASS[icon] || 'al-info';

        var row = document.createElement('div');
        row.className = 'al-entry ' + cls;

        var timeEl = document.createElement('span');
        timeEl.className = 'al-time';
        timeEl.textContent = time;

        var iconEl = document.createElement('span');
        iconEl.className = 'al-icon';
        iconEl.textContent = icon;

        var msgEl = document.createElement('span');
        msgEl.className = 'al-msg';
        msgEl.textContent = msg;

        row.appendChild(timeEl);
        row.appendChild(iconEl);
        row.appendChild(msgEl);
        el.appendChild(row);

        // Limita a 300 entradas visíveis
        var children = el.children;
        while (children.length > 300) el.removeChild(children[0]);

        alCount++;
        document.getElementById('al-count').textContent = alCount + (alCount === 1 ? ' evento' : ' eventos');

        if (alAutoScroll) el.scrollTop = el.scrollHeight;
    }

    /**
     * Recebe nova entrada em tempo real vinda do Kotlin via AppLog listener.
     * Chamado pelo bridge notifyWebAppLogEntry().
     */
    window.onAppLogEntry = function(raw) {
        appendAlEntry(raw);
    };

    /**
     * Abre o modal de log.
     * Carrega o snapshot atual do AppLog para preencher entradas anteriores.
     */
    function openLogModal() {
        var modal = document.getElementById('log-modal');
        modal.classList.add('open');
        alAutoScroll = true;

        var el = document.getElementById('log-content');
        el.onscroll = function() {
            alAutoScroll = el.scrollTop + el.clientHeight >= el.scrollHeight - 40;
        };

        // Carrega snapshot existente (entradas que ocorreram antes do modal abrir)
        el.innerHTML = '';
        alCount = 0;
        document.getElementById('al-count').textContent = '0 eventos';

        if (window.Android && Android.getAppLog) {
            try {
                var entries = JSON.parse(Android.getAppLog());
                if (entries && entries.length > 0) {
                    entries.forEach(function(e) { appendAlEntry(e); });
                } else {
                    renderAlEmpty();
                }
            } catch(e) {
                renderAlEmpty();
            }
        } else {
            renderAlEmpty();
        }
    }

    function closeLogModal() {
        document.getElementById('log-modal').classList.remove('open');
    }

    /** Exibe estado vazio quando não há entradas */
    function renderAlEmpty() {
        var el = document.getElementById('log-content');
        el.innerHTML = '';
        var empty = document.createElement('div');
        empty.className = 'log-empty';
        empty.innerHTML =
            '<span class="log-empty-icon">📋</span>' +
            '<span class="log-empty-text">Nenhum evento registrado.<br>Conecte-se para ver o status aqui.</span>';
        el.appendChild(empty);
    }

    /** Limpa o log */
    function clearAppLog() {
        if (window.Android && Android.clearAppLog) Android.clearAppLog();
        var el = document.getElementById('log-content');
        el.innerHTML = '';
        alCount = 0;
        document.getElementById('al-count').textContent = '0 eventos';
        renderAlEmpty();
    }

    /** Copia o log como texto */
    function copyAppLog() {
        var el = document.getElementById('log-content');
        var lines = [];
        var entries = el.querySelectorAll('.al-entry');
        entries.forEach(function(row) {
            var spans = row.querySelectorAll('span');
            if (spans.length >= 3) {
                lines.push(spans[0].textContent + ' ' + spans[1].textContent + ' ' + spans[2].textContent);
            }
        });
        var text = lines.join('\n');
        if (window.Android && Android.copyToClipboard) {
            Android.copyToClipboard(text);
            showToast('📋 LOG COPIADO', '#4a9eff', true);
        }
    }

    // =============================================================================
    // NAVEGAÇÃO
    // =============================================================================
    function goToConfig(){window.history.pushState({page:'config'},'Config');showPage('config-screen');}
    window.onpopstate=function(){showPage('home');};
    function showPage(id){document.querySelectorAll('section').forEach(function(s){s.classList.remove('active');});document.getElementById(id).classList.add('active');}

    // =============================================================================
    // SALVAR CONFIG
    // =============================================================================
    function saveConfig(){
        var val=document.getElementById('config-input').value.trim();
        if(val&&!val.startsWith('vless://')&&!val.includes('"outbounds"')){alert('Config não reconhecido.\nUse VLESS ou JSON com "outbounds".');return;}
        storageSave('netsmon_config',val);
        var gif=document.getElementById('gif-url-input').value.trim();
        storageSave('netsmon_bg',gif);
        storageSave('netsmon_bg_cache','');
        applyBackground(gif);
        alert('Configurações salvas!');handleAndroidBack();
    }
</script>
