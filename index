<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
    <title>NETSIMON</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI',sans-serif; }
        html, body { height:100%; overflow:hidden; background:#000; color:#fff; }
        :root {
            --purple: #6F00FF;
            --blue:   #001F3F;
            --glow:   #007BFF;
            --green:  #2ecc71;
            --red:    #e74c3c;
        }

        #neon-canvas { position:fixed; inset:0; z-index:1; pointer-events:none; }
        #bg-layer {
            position:fixed; inset:0; z-index:2;
            background-size:cover; background-position:center; background-repeat:no-repeat;
            opacity:0; pointer-events:none; transition:opacity 0.8s ease;
        }
        #bg-layer.loaded { opacity:0.25; }
        body { display:flex; flex-direction:column; align-items:center; position:relative; z-index:3; }

        @keyframes colorBreeze {
            0%   { background-position:0% 50%; }
            50%  { background-position:100% 50%; }
            100% { background-position:0% 50%; }
        }
        @keyframes fadeIn  { from{opacity:0} to{opacity:1} }
        @keyframes twinkle {
            0%,100% { opacity:1; filter:brightness(1) drop-shadow(0 0 6px #007BFF); }
            40%     { opacity:.6; filter:brightness(.7) drop-shadow(0 0 2px #007BFF); }
            70%     { opacity:.9; filter:brightness(1.2) drop-shadow(0 0 12px #6F00FF); }
        }
        @keyframes pulseBlue  { 0%,100%{box-shadow:0 0 28px rgba(0,123,255,.6);} 50%{box-shadow:0 0 50px rgba(0,123,255,.95);} }
        @keyframes pulseGreen { 0%,100%{box-shadow:0 0 28px rgba(46,204,113,.6);} 50%{box-shadow:0 0 50px rgba(46,204,113,.95);} }
        @keyframes slideUp { from{transform:translateY(100%);opacity:0;} to{transform:translateY(0);opacity:1;} }
        @keyframes popIn   { from{transform:translate(-50%,-50%) scale(.85);opacity:0;} to{transform:translate(-50%,-50%) scale(1);opacity:1;} }
        @keyframes spin    { to{transform:rotate(360deg);} }
        @keyframes pulseRed { 0%,100%{opacity:1;} 50%{opacity:.5;} }

        #update-toast {
            position:fixed; bottom:28px; left:50%; transform:translateX(-50%);
            background:rgba(15,15,15,.95); border:1px solid #2ecc71; color:#2ecc71;
            font-size:.72rem; font-weight:700; letter-spacing:1.5px; text-transform:uppercase;
            padding:8px 22px; border-radius:30px; white-space:nowrap; pointer-events:none;
            z-index:9999; opacity:0; box-shadow:0 0 14px rgba(46,204,113,.3); transition:opacity .45s ease;
        }
        #update-toast.show { opacity:1; }

        header { padding:18px 0 6px 0; flex-shrink:0; display:flex; flex-direction:column; align-items:center; gap:2px; }
        .logo-wrap { position:relative; display:inline-block; cursor:pointer; }
        .logo-wrap img {
            width:140px; display:block;
            animation:twinkle 3.5s ease-in-out infinite;
            filter:drop-shadow(0 0 18px rgba(0,123,255,.7));
        }
        .logo-wrap::after {
            content:''; position:absolute; inset:-12px;
            background:radial-gradient(ellipse at center, rgba(0,123,255,.35) 0%, transparent 70%);
            pointer-events:none; animation:pulseBlue 3.5s ease-in-out infinite; border-radius:50%;
        }

        main { width:100%; max-width:450px; flex-grow:1; display:flex; flex-direction:column; padding:10px 14px; }
        section { display:none; width:100%; height:100%; flex-direction:column; align-items:center; justify-content:space-between; padding-bottom:14px; }
        section.active { display:flex; animation:fadeIn .4s; }

        .breeze-card {
            background:linear-gradient(135deg,var(--purple),#000,var(--blue),#000,var(--purple));
            background-size:300% 300%; animation:colorBreeze 8s linear infinite;
            border:1px solid var(--glow); box-shadow:0 0 12px rgba(0,123,255,.3);
            border-radius:10px; text-align:center;
        }
        .info-container { display:flex; gap:10px; width:100%; }
        .info-box { flex:1; padding:8px 10px; }
        .info-label { font-size:.58rem; color:#aaa; text-transform:uppercase; font-weight:bold; margin-bottom:2px; display:block; letter-spacing:1px; }
        .info-value { font-size:.85rem; font-family:monospace; font-weight:bold; }

        .operator-btn { display:flex; flex-direction:column; align-items:center; gap:6px; cursor:pointer; margin:8px 0; background:none; border:none; color:#fff; }
        .operator-circle {
            width:56px; height:56px; border-radius:50%; background:#0a1628;
            display:flex; align-items:center; justify-content:center;
            border:2px solid var(--glow); box-shadow:0 0 14px rgba(0,123,255,.5);
            overflow:hidden; transition:box-shadow .2s;
        }
        .operator-circle:active { box-shadow:0 0 24px rgba(0,123,255,.9); }
        .operator-circle img { width:100%; height:100%; object-fit:cover; }
        .operator-name { font-size:.62rem; color:#aaa; text-transform:uppercase; letter-spacing:1px; }

        #btn-connection {
            width:155px; height:155px; border-radius:50%;
            border:4px solid var(--glow); color:#fff; font-size:1.25rem; font-weight:900; cursor:pointer;
            background:linear-gradient(135deg,var(--purple),#000,var(--blue),#000,var(--purple));
            background-size:300% 300%;
            animation:colorBreeze 5s linear infinite, pulseBlue 3s ease-in-out infinite;
            letter-spacing:2px; transition:border-color .3s;
        }
        #btn-connection.active { border-color:var(--green); animation:colorBreeze 5s linear infinite, pulseGreen 3s ease-in-out infinite; }
        #btn-connection.connecting { border-color:#f39c12; animation:colorBreeze 5s linear infinite; font-size:1rem; }

        .status-text { font-size:.95rem; font-weight:900; margin-top:7px; height:20px; text-transform:uppercase; letter-spacing:1px; }
        .connected  { color:var(--green); text-shadow:0 0 10px var(--green); }
        .error-text { color:var(--red); }
        .warn-text  { color:#f39c12; }

        .uuid-box { width:100%; background:transparent; border:none; color:#fff; font-family:monospace; font-size:.92rem; text-align:center; font-weight:bold; outline:none; }
        .app-version { font-size:.55rem; color:#333; letter-spacing:2px; text-transform:uppercase; text-align:center; margin-top:5px; display:block; }

        #uuid-section { width:100%; transition:opacity .3s; }
        #uuid-section.hidden { display:none; }

        #user-info-card {
            display:none; width:100%;
            background:linear-gradient(135deg,rgba(0,40,80,.9),rgba(10,0,30,.9),rgba(0,40,80,.9));
            border:1px solid rgba(0,123,255,.4);
            border-radius:12px; padding:10px 12px 8px;
            animation:fadeIn .4s;
            position:relative;
        }
        #user-info-card.show { display:block; }

        .cu-header {
            display:flex; align-items:center; justify-content:space-between;
            margin-bottom:8px;
        }
        .cu-title {
            font-size:.55rem; color:#4a9eff; text-transform:uppercase;
            letter-spacing:1.5px; font-weight:700;
        }
        .cu-refresh-btn {
            background:transparent; border:1px solid #1a3560; color:#2a5090;
            border-radius:50%; width:22px; height:22px; cursor:pointer;
            display:flex; align-items:center; justify-content:center; font-size:.7rem;
            transition:all .2s; padding:0; flex-shrink:0;
        }
        .cu-refresh-btn:active { border-color:var(--glow); color:var(--glow); }
        .cu-refresh-btn.spinning span { display:inline-block; animation:spin .7s linear infinite; }

        .cu-grid {
            display:grid; grid-template-columns:1fr 1fr;
            gap:6px;
        }
        .cu-item {
            background:rgba(0,0,0,.4); border-radius:8px; padding:7px 10px;
            display:flex; flex-direction:column; gap:2px;
        }
        .cu-item-label {
            font-size:.5rem; color:#3a6090; text-transform:uppercase;
            letter-spacing:1px; font-weight:700;
        }
        .cu-item-value {
            font-size:.78rem; font-family:monospace; font-weight:bold; color:#ccc;
            white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
        }
        .cu-item-value.good  { color:#2ecc71; }
        .cu-item-value.warn  { color:#f39c12; }
        .cu-item-value.bad   { color:#e74c3c; animation:pulseRed 1.2s ease-in-out infinite; }

        .cu-loading {
            display:flex; align-items:center; justify-content:center; gap:8px;
            padding:6px 0; font-size:.65rem; color:#2a5090; letter-spacing:1px;
        }
        .cu-spin { width:12px; height:12px; border:2px solid #1a3560; border-top-color:#4a9eff; border-radius:50%; animation:spin .7s linear infinite; }

        .cu-error {
            font-size:.6rem; color:#8a3030; text-align:center; padding:4px 0; letter-spacing:.5px;
        }

        .config-area { width:100%; flex:1; display:flex; flex-direction:column; gap:12px; padding:10px; }
        textarea { height:30%; background:#0a0a0a; border:1px solid #333; color:#2ecc71; padding:12px; font-family:monospace; font-size:.8rem; border-radius:10px; resize:none; outline:none; }
        .gif-field { background:#0a0a0a; border:1px solid #333; color:#aaa; padding:10px 12px; font-family:monospace; font-size:.78rem; border-radius:10px; outline:none; width:100%; }
        .gif-field::placeholder { color:#444; }
        .btn-save { background:var(--glow); color:#fff; border:none; padding:13px; border-radius:10px; font-weight:bold; cursor:pointer; font-size:.9rem; }
        .btn-cancel { background:transparent; color:#555; border:none; padding:13px; font-weight:bold; cursor:pointer; margin-bottom:12px; }
        .field-label { font-size:.6rem; color:#666; text-transform:uppercase; letter-spacing:1px; margin-bottom:2px; }

        #log-btn {
            position:fixed; bottom:18px; left:18px; z-index:500;
            width:36px; height:36px; border-radius:50%;
            background:rgba(10,10,30,.85); border:1px solid #1a2540; color:#334; font-size:.9rem;
            display:flex; align-items:center; justify-content:center;
            cursor:pointer; transition:all .2s; box-shadow:0 2px 8px rgba(0,0,0,.5);
        }
        #log-btn:hover, #log-btn:active { border-color:var(--glow); color:var(--glow); }

        #ssh-cred-btn {
            position:fixed; bottom:18px; right:18px; z-index:500;
            width:36px; height:36px; border-radius:50%;
            background:rgba(10,10,30,.85); border:1px solid #1a2540; color:#334; font-size:.9rem;
            display:flex; align-items:center; justify-content:center;
            cursor:pointer; transition:all .2s; box-shadow:0 2px 8px rgba(0,0,0,.5); position:fixed;
        }
        #ssh-cred-btn:hover, #ssh-cred-btn:active { border-color:var(--glow); color:var(--glow); }
        #ssh-cred-btn.has-creds::after { content:''; position:absolute; top:2px; right:2px; width:8px; height:8px; border-radius:50%; background:var(--green); border:1px solid #000; }

        .bottom-modal { display:none; position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,.75); align-items:flex-end; }
        .bottom-modal.open { display:flex; animation:fadeIn .2s; }
        .modal-sheet { width:100%; max-width:450px; margin:0 auto; background:#0a0a18; border-top:1px solid #222; border-radius:18px 18px 0 0; padding:0 0 24px; animation:slideUp .3s ease; max-height:80vh; overflow-y:auto; }
        .modal-handle { width:40px; height:4px; background:#333; border-radius:2px; margin:12px auto 16px; }
        .modal-title { text-align:center; font-size:.7rem; color:#555; text-transform:uppercase; letter-spacing:2px; margin-bottom:16px; }
        .cat-tabs { display:flex; gap:8px; padding:0 16px; overflow-x:auto; scrollbar-width:none; margin-bottom:14px; }
        .cat-tabs::-webkit-scrollbar { display:none; }
        .cat-tab { flex-shrink:0; padding:6px 16px; border:1px solid #333; border-radius:20px; background:transparent; color:#777; font-size:.68rem; font-weight:700; text-transform:uppercase; letter-spacing:1px; cursor:pointer; transition:all .2s; }
        .cat-tab.active { border-color:var(--glow); color:#fff; background:rgba(0,123,255,.15); }
        .op-list { padding:0 12px; display:flex; flex-direction:column; gap:8px; }
        .op-item { display:flex; align-items:center; gap:12px; padding:12px 14px; background:#0f1626; border:1px solid #1a2540; border-radius:12px; cursor:pointer; transition:all .2s; position:relative; }
        .op-item:active { border-color:var(--glow); background:#0a1a35; }
        .op-item.selected { border-color:var(--green); background:rgba(46,204,113,.07); }
        .op-icon { width:40px; height:40px; border-radius:50%; object-fit:cover; border:1px solid #222; flex-shrink:0; background:#0a0a0a; }
        .op-info { flex:1; min-width:0; }
        .op-name { font-size:.82rem; font-weight:700; color:#eee; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .op-desc { font-size:.65rem; color:#555; margin-top:2px; }
        .op-mode-badge { font-size:.55rem; font-weight:700; letter-spacing:1px; padding:3px 8px; border-radius:8px; text-transform:uppercase; flex-shrink:0; }
        .badge-ssh   { background:rgba(0,123,255,.2); color:#4a9eff; border:1px solid #1a4a80; }
        .badge-v2ray { background:rgba(111,0,255,.2); color:#a855f7; border:1px solid #4a1a80; }
        .badge-ssl   { background:rgba(46,204,113,.2); color:#2ecc71; border:1px solid #1a5035; }
        .badge-other { background:rgba(255,255,255,.1); color:#aaa; border:1px solid #333; }
        .op-check { width:18px; height:18px; border-radius:50%; border:2px solid #333; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:.65rem; transition:all .2s; }
        .op-item.selected .op-check { background:var(--green); border-color:var(--green); }
        .op-item.selected .op-check::after { content:'✓'; color:#000; font-weight:900; }
        .modal-close-btn { display:block; width:calc(100% - 32px); margin:16px 16px 0; padding:14px; background:transparent; border:1px solid #222; color:#555; border-radius:12px; font-size:.85rem; cursor:pointer; }

        #ssh-popup-overlay { display:none; position:fixed; inset:0; z-index:2000; background:rgba(0,0,0,.85); align-items:center; justify-content:center; }
        #ssh-popup-overlay.open { display:flex; }
        .ssh-popup { position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); width:calc(100% - 40px); max-width:360px; background:#0a0a1a; border:1px solid #1a2a50; border-radius:18px; padding:24px 20px 20px; animation:popIn .25s ease; z-index:2001; }
        .ssh-popup-icon { width:48px; height:48px; border-radius:50%; background:rgba(0,123,255,.15); border:1px solid #1a4a80; display:flex; align-items:center; justify-content:center; font-size:1.4rem; margin:0 auto 14px; }
        .ssh-popup h3 { text-align:center; font-size:.9rem; font-weight:700; letter-spacing:1px; margin-bottom:4px; }
        .ssh-popup .ssh-popup-sub { text-align:center; font-size:.68rem; color:#555; margin-bottom:20px; line-height:1.5; }
        .ssh-field-group { display:flex; flex-direction:column; gap:10px; margin-bottom:18px; }
        .ssh-field-wrap { position:relative; }
        .ssh-field-label { font-size:.58rem; color:#555; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px; display:block; }
        .ssh-field { width:100%; background:#050510; border:1px solid #1a2540; color:#fff; padding:12px 14px; border-radius:10px; font-family:monospace; font-size:.88rem; outline:none; transition:border-color .2s; }
        .ssh-field:focus { border-color:var(--glow); }
        .ssh-field::placeholder { color:#2a3040; }
        .pwd-toggle { position:absolute; right:12px; top:50%; transform:translateY(-50%); background:none; border:none; color:#444; cursor:pointer; font-size:.8rem; padding:4px; }
        .ssh-popup-btns { display:flex; gap:10px; }
        .ssh-btn-confirm { flex:1; background:var(--glow); color:#fff; border:none; padding:13px; border-radius:10px; font-weight:700; font-size:.88rem; cursor:pointer; }
        .ssh-btn-cancel { flex:0 0 auto; background:transparent; color:#444; border:1px solid #1a2540; padding:13px 18px; border-radius:10px; font-size:.88rem; cursor:pointer; }
        .ssh-error-msg { display:none; font-size:.68rem; color:var(--red); text-align:center; margin-top:-10px; margin-bottom:10px; }
        .ssh-error-msg.show { display:block; }
        .ssh-saved-info { display:flex; align-items:center; gap:8px; background:rgba(46,204,113,.08); border:1px solid rgba(46,204,113,.2); border-radius:8px; padding:8px 12px; margin-bottom:16px; font-size:.68rem; color:#2ecc71; }

        /* =====================================================================
           LOG MODAL — estilo HTTP Injector
           Entradas simples: hora | emoji | mensagem
           Cores por categoria de ícone
        ===================================================================== */
        #log-modal {
            display:none; position:fixed; inset:0; z-index:3000;
            background:#02050e; flex-direction:column;
        }
        #log-modal.open { display:flex; animation:fadeIn .15s; }

        .log-header {
            display:flex; align-items:center; justify-content:space-between;
            padding:12px 14px 10px;
            background:linear-gradient(180deg,#030a1a 0%,#020610 100%);
            border-bottom:1px solid #0d1828;
            flex-shrink:0;
        }
        .log-title-wrap { display:flex; flex-direction:column; gap:2px; }
        .log-title {
            font-size:.72rem; font-weight:800; color:#3a7abf;
            text-transform:uppercase; letter-spacing:2.5px;
        }
        .log-subtitle {
            font-size:.52rem; color:#1a3050; letter-spacing:1px;
            text-transform:uppercase;
        }
        .log-header-btns { display:flex; gap:6px; align-items:center; }
        .log-hbtn {
            background:transparent; border:1px solid #0d1828; color:#2a4060;
            padding:5px 10px; border-radius:6px; font-size:.6rem; font-weight:700;
            text-transform:uppercase; letter-spacing:1px; cursor:pointer; transition:all .15s;
        }
        .log-hbtn:active { border-color:#3a7abf; color:#3a7abf; }
        .log-hbtn.danger:active { border-color:#8a2020; color:#e74c3c; }
        #log-close-btn {
            background:transparent; border:none; color:#2a4060;
            font-size:1rem; cursor:pointer; padding:4px 6px; line-height:1;
        }
        #log-close-btn:active { color:#fff; }

        /* Barra de status/contagem */
        .log-status-bar {
            display:flex; align-items:center; gap:8px;
            padding:5px 14px 4px;
            background:#020610;
            border-bottom:1px solid #080f1e;
            flex-shrink:0;
        }
        .log-live-dot {
            width:6px; height:6px; border-radius:50%; background:#1a5a30;
            flex-shrink:0;
        }
        .log-live-dot.active {
            background:#2ecc71; box-shadow:0 0 5px rgba(46,204,113,.6);
            animation:blink 1.4s ease-in-out infinite;
        }
        @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:.25;} }
        .log-count { font-size:.56rem; color:#1a3050; letter-spacing:1px; margin-left:auto; }

        /* Área de entradas */
        #log-content {
            flex:1; overflow-y:auto; padding:4px 0;
            scroll-behavior:smooth;
        }
        #log-content::-webkit-scrollbar { width:3px; }
        #log-content::-webkit-scrollbar-track { background:#020610; }
        #log-content::-webkit-scrollbar-thumb { background:#0d1828; border-radius:2px; }

        /* Entrada individual */
        .al-entry {
            display:flex; align-items:flex-start;
            padding:7px 14px 6px;
            border-bottom:1px solid rgba(255,255,255,.022);
            gap:0;
            transition:background .1s;
        }
        .al-entry:active { background:rgba(255,255,255,.03); }

        .al-time {
            flex-shrink:0; width:54px;
            font-size:.6rem; font-family:'Courier New', monospace;
            color:#0d2035; margin-top:1px; letter-spacing:.3px;
        }
        .al-icon {
            flex-shrink:0; width:22px;
            font-size:.78rem; text-align:center; margin-top:-1px;
        }
        .al-msg {
            flex:1; font-size:.72rem; line-height:1.4;
            letter-spacing:.2px; word-break:break-word;
        }

        /* Cores por categoria */
        .al-success .al-msg { color:#2ecc71; }
        .al-success .al-time { color:#0d3020; }

        .al-error .al-msg   { color:#e74c3c; }
        .al-error .al-time  { color:#3d0d0d; }

        .al-warn .al-msg    { color:#e67e22; }
        .al-warn .al-time   { color:#3d2200; }

        .al-connect .al-msg  { color:#3498db; }
        .al-connect .al-time { color:#0d2035; }

        .al-disconnect .al-msg  { color:#7f8c8d; }
        .al-disconnect .al-time { color:#0d1520; }

        .al-ping .al-msg  { color:#1abc9c; }
        .al-ping .al-time { color:#0a2520; }

        .al-ip .al-msg  { color:#5dade2; }
        .al-ip .al-time { color:#0d2035; }

        .al-user .al-msg  { color:#a569bd; }
        .al-user .al-time { color:#2a0d40; }

        .al-update .al-msg  { color:#58d68d; }
        .al-update .al-time { color:#0a2a18; }

        .al-info .al-msg  { color:#2a4060; }
        .al-info .al-time { color:#0d1520; }

        .al-reconnect .al-msg  { color:#f39c12; }
        .al-reconnect .al-time { color:#3d2800; }

        /* Estado vazio */
        .log-empty {
            display:flex; flex-direction:column; align-items:center; justify-content:center;
            height:100%; gap:10px; color:#0d1828; padding:40px;
        }
        .log-empty-icon { font-size:2rem; opacity:.4; }
        .log-empty-text { font-size:.65rem; letter-spacing:2px; text-transform:uppercase; text-align:center; line-height:1.6; }

        /* Separador de sessão */
        .al-separator {
            text-align:center; font-size:.52rem; color:#0d1828;
            letter-spacing:2px; padding:6px 14px; text-transform:uppercase;
            border-bottom:1px solid rgba(255,255,255,.022);
        }
    </style>
</head>
<body>

<canvas id="neon-canvas"></canvas>
<div id="bg-layer"></div>
<div id="update-toast"></div>

<header>
    <div class="logo-wrap" onclick="checkUpdatesManual()" title="Toque para verificar atualizações">
        <img id="logo-img"
             src="file:///android_asset/logo.png"
             onerror="this.onerror=null;this.src='https://i.ibb.co/ccC6BNw/ei-1699404424073-removebg-preview.png'"/>
    </div>
</header>

<main>
    <!-- HOME -->
    <section id="home" class="active">
        <div class="info-container">
            <div class="info-box breeze-card">
                <span class="info-label">CONECTADO</span>
                <span class="info-value" id="timer-display">--:--:--</span>
            </div>
            <div class="info-box breeze-card" onclick="requestPing()" style="cursor:pointer">
