<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
    <title>NETSIMON</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI',sans-serif; }

        html, body { height:100%; overflow:hidden; background:#000; color:#fff; }

        :root {
            --purple: #6F00FF;
            --blue:   #001F3F;
            --glow:   #007BFF;
            --green:  #2ecc71;
            --red:    #e74c3c;
        }

        #bg-layer {
            position: fixed; inset: 0; z-index: 0;
            background-size: cover; background-position: center;
            background-repeat: no-repeat;
            opacity: 0.18;
            pointer-events: none;
        }

        body { display:flex; flex-direction:column; align-items:center; position:relative; z-index:1; }

        @keyframes colorBreeze {
            0%   { background-position:0% 50%; }
            50%  { background-position:100% 50%; }
            100% { background-position:0% 50%; }
        }
        @keyframes fadeIn { from{opacity:0} to{opacity:1} }
        @keyframes twinkle {
            0%,100% { opacity:1; filter:brightness(1) drop-shadow(0 0 6px #007BFF); }
            40%     { opacity:.6; filter:brightness(.7) drop-shadow(0 0 2px #007BFF); }
            70%     { opacity:.9; filter:brightness(1.2) drop-shadow(0 0 12px #6F00FF); }
        }
        @keyframes pulseBlue {
            0%,100% { box-shadow:0 0 28px rgba(0,123,255,.6); }
            50%     { box-shadow:0 0 50px rgba(0,123,255,.95); }
        }
        @keyframes pulseGreen {
            0%,100% { box-shadow:0 0 28px rgba(46,204,113,.6); }
            50%     { box-shadow:0 0 50px rgba(46,204,113,.95); }
        }

        header {
            padding:18px 0 6px 0; flex-shrink:0;
            display:flex; flex-direction:column; align-items:center; gap:2px;
            position:relative;
        }
        .logo-wrap { position:relative; display:inline-block; }
        .logo-wrap img {
            width:140px; display:block;
            animation: twinkle 3.5s ease-in-out infinite;
            filter: drop-shadow(0 0 18px rgba(0,123,255,.7));
        }
        .logo-wrap::after {
            content:'';
            position:absolute; inset:-12px;
            background: radial-gradient(ellipse at center, rgba(0,123,255,.35) 0%, transparent 70%);
            pointer-events:none;
            animation: pulseBlue 3.5s ease-in-out infinite;
            border-radius:50%;
        }

        main { width:100%; max-width:450px; flex-grow:1; display:flex; flex-direction:column; padding:10px 14px; }

        section { display:none; width:100%; height:100%; flex-direction:column; align-items:center; justify-content:space-between; padding-bottom:14px; }
        section.active { display:flex; animation:fadeIn .4s; }

        .breeze-card {
            background: linear-gradient(135deg,var(--purple),#000,var(--blue),#000,var(--purple));
            background-size:300% 300%;
            animation: colorBreeze 8s linear infinite;
            border:1px solid var(--glow);
            box-shadow:0 0 12px rgba(0,123,255,.3);
            border-radius:10px;
            text-align:center;
        }
        .info-container { display:flex; gap:10px; width:100%; }
        .info-box { flex:1; padding:8px 10px; }
        .info-label { font-size:.58rem; color:#aaa; text-transform:uppercase; font-weight:bold; margin-bottom:2px; display:block; letter-spacing:1px; }
        .info-value { font-size:.85rem; font-family:monospace; font-weight:bold; }

        .server-selector-wrapper {
            display:flex; flex-direction:column; align-items:center;
            margin:8px 0; opacity:.45; pointer-events:none;
        }
        .server-circle {
            width:50px; height:50px; border-radius:50%;
            background:#004691;
            display:flex; align-items:center; justify-content:center;
            border:2px solid var(--glow);
            box-shadow:0 0 12px rgba(0,123,255,.4);
            overflow:hidden;
        }
        .server-circle img { width:100%; height:100%; object-fit:cover; }

        #btn-connection {
            width:155px; height:155px; border-radius:50%;
            border:4px solid var(--glow);
            color:#fff; font-size:1.25rem; font-weight:900; cursor:pointer;
            background: linear-gradient(135deg,var(--purple),#000,var(--blue),#000,var(--purple));
            background-size:300% 300%;
            animation: colorBreeze 5s linear infinite, pulseBlue 3s ease-in-out infinite;
            letter-spacing:2px; transition:border-color .3s;
        }
        #btn-connection.active {
            border-color:var(--green);
            animation: colorBreeze 5s linear infinite, pulseGreen 3s ease-in-out infinite;
        }
        #btn-connection:disabled { opacity:.5; cursor:not-allowed; }

        .status-text {
            font-size:.95rem; font-weight:900; margin-top:7px;
            height:20px; text-transform:uppercase; letter-spacing:1px;
        }
        .connected  { color:var(--green); text-shadow:0 0 10px var(--green); }
        .error-text { color:var(--red); }

        .uuid-box {
            width:100%; background:transparent; border:none;
            color:#fff; font-family:monospace; font-size:.92rem;
            text-align:center; font-weight:bold; outline:none;
        }

        /* versão — no lugar onde ficava a validade */
        .app-version {
            font-size:.55rem; color:#333; letter-spacing:2px;
            text-transform:uppercase; text-align:center;
            margin-top:5px; display:block;
        }

        .config-area { width:100%; flex:1; display:flex; flex-direction:column; gap:12px; padding:10px; }
        textarea {
            height:30%;
            background:#0a0a0a; border:1px solid #333;
            color:#2ecc71; padding:12px;
            font-family:monospace; font-size:.8rem;
            border-radius:10px; resize:none; outline:none;
        }
        .gif-field {
            background:#0a0a0a; border:1px solid #333; color:#aaa;
            padding:10px 12px; font-family:monospace; font-size:.78rem;
            border-radius:10px; outline:none; width:100%;
        }
        .gif-field::placeholder { color:#444; }
        .btn-save {
            background:var(--glow); color:#fff; border:none;
            padding:13px; border-radius:10px; font-weight:bold;
            cursor:pointer; font-size:.9rem;
        }
        .btn-cancel {
            background:transparent; color:#555; border:none;
            padding:13px; font-weight:bold; cursor:pointer; margin-bottom:12px;
        }
        .field-label { font-size:.6rem; color:#666; text-transform:uppercase; letter-spacing:1px; margin-bottom:2px; }
    </style>
</head>
<body>

<div id="bg-layer"></div>

<header>
    <div class="logo-wrap">
        <img id="logo-img" src="https://i.ibb.co/ccC6BNw/ei-1699404424073-removebg-preview.png"/>
    </div>
</header>

<main>

    <!-- ==================== HOME ==================== -->
    <section id="home" class="active">

        <!-- Cards: cronômetro à esquerda, IP/Ping à direita -->
        <div class="info-container">
            <div class="info-box breeze-card">
                <span class="info-label">CONECTADO</span>
                <span class="info-value" id="timer-display">--:--:--</span>
            </div>
            <div class="info-box breeze-card" onclick="requestPing()" style="cursor:pointer" title="Toque para medir novamente">
                <span class="info-label">IP / PING</span>
                <span class="info-value" id="ip-display" style="font-size:.7rem;display:block;line-height:1.4">--</span>
                <span class="info-value" id="ping-display" style="font-size:.82rem">-- ms</span>
            </div>
        </div>

        <!-- Operadora (inativa) -->
        <div class="server-selector-wrapper">
            <div class="server-circle">
                <img src="https://i.ibb.co/gLrmNT8G/imagem-2026-03-27-111301414-removebg-preview.png">
            </div>
        </div>

        <!-- Botão ligar -->
        <div style="text-align:center">
            <button id="btn-connection">LIGAR</button>
            <div id="status-label" class="status-text"></div>
        </div>

        <!-- Campo UUID + versão (onde ficava a validade) -->
        <div style="width:100%">
            <span class="info-label" style="text-align:center;width:100%;display:block;margin-bottom:5px">
                CHAVE DE ACESSO (UUID)
            </span>
            <div class="breeze-card" style="padding:14px">
                <input type="text" class="uuid-box" id="user-uuid"
                       placeholder="Cole sua CHAVE aqui"
                       oninput="onUuidInput(this.value)">
            </div>
            <span class="app-version">NETSIMON v2.0</span>
        </div>

    </section>

    <!-- ==================== CONFIG ==================== -->
    <section id="config-screen">
        <h3 style="margin-top:10px;font-size:.95rem;letter-spacing:1px">CONFIGURAÇÕES AVANÇADAS</h3>
        <div class="config-area">
            <div>
                <div class="field-label">Config JSON ou VLESS personalizado (opcional)</div>
                <textarea id="config-input" placeholder="Deixe vazio para usar a config padrão do sistema."></textarea>
            </div>
            <div>
                <div class="field-label">Link do GIF / imagem / vídeo de fundo (opcional — .gif, .jpg, .mp4, .webm)</div>
                <input type="url" class="gif-field" id="gif-url-input"
                       placeholder="https://exemplo.com/animacao.gif ou video.mp4">
            </div>
            <button class="btn-save" onclick="saveConfig()">SALVAR E VOLTAR</button>
            <button class="btn-cancel" onclick="goBack()">CANCELAR</button>
        </div>
    </section>

</main>

<script>
// =============================================================================
// ⚙️ CONFIGURAÇÃO RÁPIDA — troque o link abaixo para mudar o fundo
// Suporta .gif, .jpg, .png, .mp4, .webm — deixe '' para fundo sólido preto
// =============================================================================
var DEFAULT_BG_URL = '';

// =============================================================================
// Storage
// =============================================================================
function storageSave(key, val) {
    if (window.Android && Android.storageSave) Android.storageSave(key, val);
    else try { localStorage.setItem(key, val); } catch(e) {}
}
function storageGet(key) {
    if (window.Android && Android.storageGet) return Android.storageGet(key);
    try { return localStorage.getItem(key); } catch(e) { return null; }
}

// =============================================================================
// Init
// =============================================================================
var isConnected = false;
var timerInterval = null;
var connectTime = null;
var uuidPattern = /^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$/;

window.addEventListener('load', function() {
    var savedUuid = storageGet('netsmon_uuid');
    if (savedUuid) document.getElementById('user-uuid').value = savedUuid;

    var savedConfig = storageGet('netsmon_config');
    if (savedConfig) document.getElementById('config-input').value = savedConfig;

    var savedGif = storageGet('netsmon_bg');
    applyBackground(savedGif || DEFAULT_BG_URL);
    document.getElementById('gif-url-input').value = savedGif || DEFAULT_BG_URL;

    if (window.Android && Android.checkUpdates) Android.checkUpdates();
});

// =============================================================================
// Background — GIF, imagem ou vídeo MP4/WebM
// =============================================================================
function applyBackground(url) {
    var bg = document.getElementById('bg-layer');
    var oldVideo = document.getElementById('bg-video');
    if (oldVideo) oldVideo.remove();
    if (!url || url.trim() === '') { bg.style.backgroundImage = 'none'; return; }
    url = url.trim();
    if (/\.(mp4|webm|ogg)(\?.*)?$/i.test(url)) {
        bg.style.backgroundImage = 'none';
        var v = document.createElement('video');
        v.id = 'bg-video'; v.src = url; v.autoplay = true; v.loop = true;
        v.muted = true; v.playsInline = true;
        v.style.cssText = 'position:fixed;inset:0;z-index:0;width:100%;height:100%;object-fit:cover;opacity:0.18;pointer-events:none';
        document.body.insertBefore(v, document.body.firstChild);
    } else {
        bg.style.backgroundImage = "url('" + url + "')";
    }
}

// =============================================================================
// UUID input
// =============================================================================
function onUuidInput(val) { /* reservado para uso futuro */ }

// =============================================================================
// Cronômetro
// =============================================================================
function startTimer() {
    connectTime = Date.now();
    timerInterval = setInterval(function() {
        var e = Math.floor((Date.now() - connectTime) / 1000);
        var h = Math.floor(e / 3600), m = Math.floor((e % 3600) / 60), s = e % 60;
        document.getElementById('timer-display').textContent = pad(h)+':'+pad(m)+':'+pad(s);
    }, 1000);
}
function stopTimer() {
    clearInterval(timerInterval); timerInterval = null; connectTime = null;
    document.getElementById('timer-display').textContent = '--:--:--';
}
function pad(n) { return n < 10 ? '0'+n : ''+n; }

// =============================================================================
// Ping + IP (toque no card direito para refazer)
// =============================================================================
function requestPing() {
    if (!isConnected) return;
    document.getElementById('ping-display').textContent = 'medindo...';
    document.getElementById('ip-display').textContent = 'buscando...';
    if (window.Android && Android.measurePingNow) Android.measurePingNow();
}

window.onPingResult = function(ping, ip) {
    document.getElementById('ping-display').textContent = ping < 0 ? 'timeout' : ping + ' ms';
    if (ip && ip !== '') document.getElementById('ip-display').textContent = ip;
};

// =============================================================================
// Tunnel state
// =============================================================================
window.onTunnelState = function(state) {
    var btn = document.getElementById('btn-connection');
    var sl  = document.getElementById('status-label');
    btn.disabled = false;

    if (state.error) {
        isConnected = false; stopTimer();
        btn.innerText = 'LIGAR'; btn.classList.remove('active');
        sl.classList.remove('connected'); sl.classList.add('error-text');
        document.getElementById('ping-display').textContent = '-- ms';
        document.getElementById('ip-display').textContent = '--';
        var msgs = { import_failed:'CONFIG INVÁLIDO', permission_denied:'PERMISSÃO NEGADA', exception:'ERRO INTERNO' };
        sl.innerText = msgs[state.error] || 'ERRO';
        if (state.error === 'import_failed') alert('Não foi possível importar o config. Verifique o JSON.');
        return;
    }

    sl.classList.remove('error-text');
    if (state.running) {
        isConnected = true; startTimer();
        btn.innerText = 'PARAR'; btn.classList.add('active');
        sl.innerText = 'CONECTADO'; sl.classList.add('connected');
        document.getElementById('ping-display').textContent = 'medindo...';
        document.getElementById('ip-display').textContent = 'buscando...';
    } else {
        isConnected = false; stopTimer();
        btn.innerText = 'LIGAR'; btn.classList.remove('active');
        sl.innerText = ''; sl.classList.remove('connected');
        document.getElementById('ping-display').textContent = '-- ms';
        document.getElementById('ip-display').textContent = '--';
    }
};

// =============================================================================
// Botão ligar/desligar
// =============================================================================
document.getElementById('btn-connection').onclick = function() {
    var btn  = document.getElementById('btn-connection');
    var sl   = document.getElementById('status-label');
    var uuid = document.getElementById('user-uuid').value.trim();

    if (!uuid) { alert('Insira sua CHAVE DE ACESSO (UUID)!'); return; }
    if (!uuidPattern.test(uuid)) { alert('UUID inválido.\nFormato: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'); return; }

    storageSave('netsmon_uuid', uuid);

    if (btn.innerText === 'LIGAR') {
        btn.disabled = true;
        sl.innerText = 'CONECTANDO...';
        sl.classList.add('connected'); sl.classList.remove('error-text');
        document.getElementById('ping-display').textContent = 'aguarde...';
        if (window.Android) {
            Android.startTunnel(uuid);
        } else {
            // Simulação para teste no browser
            setTimeout(function() {
                window.onTunnelState({running:true, error:null});
                setTimeout(function(){ window.onPingResult(87, '187.23.10.42'); }, 1500);
            }, 1200);
        }
    } else {
        btn.disabled = true;
        if (window.Android) Android.stopTunnel();
        else window.onTunnelState({running:false, error:null});
    }
};

// =============================================================================
// Navegação
// =============================================================================
function goToConfig() {
    window.history.pushState({page:'config'}, 'Config');
    showPage('config-screen');
}
function goBack() { window.history.back(); }
window.onpopstate = function() { showPage('home'); };
function showPage(id) {
    document.querySelectorAll('section').forEach(function(s){ s.classList.remove('active'); });
    document.getElementById(id).classList.add('active');
}

// =============================================================================
// Salvar configurações avançadas
// =============================================================================
function saveConfig() {
    var val = document.getElementById('config-input').value.trim();
    if (val && !val.startsWith('vless://') && !val.includes('"outbounds"')) {
        alert('Config não reconhecido.\nUse VLESS (vless://...) ou JSON completo com "outbounds".');
        return;
    }
    storageSave('netsmon_config', val);

    var gifUrl = document.getElementById('gif-url-input').value.trim();
    storageSave('netsmon_bg', gifUrl);
    applyBackground(gifUrl);

    alert('Configurações salvas!');
    goBack();
}
</script>
</body>
</html>
