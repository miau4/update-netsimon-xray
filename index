                    <span class="cu-item-label">Usuário</span>
                    <span class="cu-item-value" id="cu-username">--</span>
                </div>
                <div class="cu-item">
                    <span class="cu-item-label">Validade</span>
                    <span class="cu-item-value" id="cu-expiry">--</span>
                </div>
                <div class="cu-item">
                    <span class="cu-item-label">Dias restantes</span>
                    <span class="cu-item-value" id="cu-days">--</span>
