<script>
    // =============================================================================
    // LINHAS NEON — rastro 400% maior (trail de 120 pontos vs 30 antes)
    // Canvas fica na camada z-index:1, abaixo da imagem de fundo (z-index:2)
    // mas acima do fundo preto sólido. As linhas CONTINUAM visíveis mesmo depois
    // que a imagem carregar porque o bg-layer (z-index:2) tem opacity:0.5,
    // deixando o neon (z-index:1) aparecer através dela.
    // =============================================================================
    (function() {
        var canvas = document.getElementById('neon-canvas');
        var ctx    = canvas.getContext('2d');

        var COLORS = [
            'rgba(0,123,255,',    // azul elétrico
            'rgba(111,0,255,',    // roxo
            'rgba(255,0,200,',    // magenta
            'rgba(0,255,180,',    // verde neon
            'rgba(0,220,255,',    // ciano
            'rgba(255,60,120,',   // rosa
            'rgba(255,160,0,',    // laranja
            'rgba(80,255,80,'     // verde
        ];

        var lines   = [];
        var NUM_LINES = 12;
        var TRAIL_LEN = 120;  // 400% do original (era 30)

        function resize() {
            canvas.width  = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        function createLine() {
            var w = canvas.width  || window.innerWidth;
            var h = canvas.height || window.innerHeight;

            var angle  = Math.random() * Math.PI * 2;
            var speed  = 0.8 + Math.random() * 2.2;
            var color  = COLORS[Math.floor(Math.random() * COLORS.length)];
            var alpha  = 0.35 + Math.random() * 0.55;
            var width  = 1.2 + Math.random() * 3.0;
            var glow   = 6 + Math.random() * 22;

            var side = Math.floor(Math.random() * 4);
            var extra = TRAIL_LEN * speed;
            var x, y;
            if      (side === 0) { x = Math.random() * w; y = -extra; }
            else if (side === 1) { x = w + extra;          y = Math.random() * h; }
            else if (side === 2) { x = Math.random() * w; y = h + extra; }
            else                 { x = -extra;             y = Math.random() * h; }

            return {
                x: x, y: y,
                vx: Math.cos(angle) * speed,
                vy: Math.sin(angle) * speed,
                color: color, alpha: alpha, width: width, glow: glow,
                age: 0,
                maxAge: 300 + Math.random() * 400,
                trail: []
            };
        }

        function init() {
            lines = [];
            for (var i = 0; i < NUM_LINES; i++) {
                var l = createLine();
                l.age = Math.random() * l.maxAge;
                lines.push(l);
            }
        }

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            for (var i = 0; i < lines.length; i++) {
                var l = lines[i];
                l.x += l.vx;
                l.y += l.vy;
                l.age++;

                l.trail.push({ x: l.x, y: l.y });
                if (l.trail.length > TRAIL_LEN) l.trail.shift();

                var lifeRatio = l.age / l.maxAge;
                var fadeFactor = lifeRatio < 0.12
                    ? lifeRatio / 0.12
                    : lifeRatio > 0.78
                        ? 1 - (lifeRatio - 0.78) / 0.22
                        : 1;

                var curAlpha = l.alpha * fadeFactor;

                if (l.trail.length >= 2) {
                    var t0 = l.trail[0], tN = l.trail[l.trail.length - 1];
                    var grad = ctx.createLinearGradient(t0.x, t0.y, tN.x, tN.y);
                    grad.addColorStop(0,   l.color + '0)');
                    grad.addColorStop(0.4, l.color + (curAlpha * 0.3).toFixed(2) + ')');
                    grad.addColorStop(1,   l.color + curAlpha.toFixed(2) + ')');

                    ctx.save();
                    ctx.shadowColor = l.color + curAlpha.toFixed(2) + ')';
                    ctx.shadowBlur  = l.glow;
                    ctx.strokeStyle = grad;
                    ctx.lineWidth   = l.width;
                    ctx.lineCap     = 'round';
                    ctx.lineJoin    = 'round';

                    ctx.beginPath();
                    ctx.moveTo(l.trail[0].x, l.trail[0].y);
                    for (var j = 1; j < l.trail.length; j++) ctx.lineTo(l.trail[j].x, l.trail[j].y);
                    ctx.stroke();

                    // Brilho extra na cabeça
                    ctx.shadowBlur  = l.glow * 2.5;
                    ctx.strokeStyle = l.color + Math.min(1, curAlpha * 1.6).toFixed(2) + ')';
                    ctx.lineWidth   = l.width * 0.45;
                    var last = l.trail.length - 1;
                    ctx.beginPath();
                    ctx.moveTo(l.trail[Math.max(0, last - 8)].x, l.trail[Math.max(0, last - 8)].y);
                    ctx.lineTo(l.trail[last].x, l.trail[last].y);
                    ctx.stroke();
                    ctx.restore();
                }

                var margin = TRAIL_LEN * (Math.abs(l.vx) + Math.abs(l.vy));
                var off = l.x < -margin || l.x > canvas.width + margin ||
                          l.y < -margin || l.y > canvas.height + margin;
                if (l.age >= l.maxAge || off) lines[i] = createLine();
            }
            requestAnimationFrame(draw);
        }

        window.addEventListener('resize', resize);
        resize(); init(); draw();
    })();

    // =============================================================================
    // Storage
    // =============================================================================
    function storageSave(key, val) {
        if (window.Android && Android.storageSave) Android.storageSave(key, val);
        else try { localStorage.setItem(key, val); } catch(e) {}
    }
    function storageGet(key) {
        if (window.Android && Android.storageGet) return Android.storageGet(key);
        try { return localStorage.getItem(key); } catch(e) { return null; }
    }

    // =============================================================================
    // Fundo padrão
    // =============================================================================
    var DEFAULT_BG_URL = 'https://i.pinimg.com/736x/a5/fa/ca/a5faca1e1d6901254aefa8ac99e26ea5.jpg';

    // =============================================================================
    // Estado global
    // =============================================================================
    var isConnected       = false;
    var timerInterval     = null;
    var connectTime       = null;
    var pingFallbackTimer = null;
    var uuidPattern = /^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$/;

    var allOperators    = [];
    var currentCategory = null;
    var selectedOpName  = null;

    var sshPopupMode = 'connect', sshPendingUuid = null, sshPendingOperator = null;

    // =============================================================================
    // Init
    // =============================================================================
    window.addEventListener('load', function() {
        var savedUuid = storageGet('netsmon_uuid');
        if (savedUuid) document.getElementById('user-uuid').value = savedUuid;

        var savedConfig = storageGet('netsmon_config');
        if (savedConfig) document.getElementById('config-input').value = savedConfig;

        var bgUrl = storageGet('netsmon_bg') || DEFAULT_BG_URL;
        if (document.getElementById('gif-url-input'))
            document.getElementById('gif-url-input').value = bgUrl;
        applyBackground(bgUrl);

        var savedOp = storageGet('netsmon_operator');
        if (savedOp) selectedOpName = savedOp;

        updateSshCredBtn();

        // ── IP local imediatamente ao abrir o app ──────────────────────────────
        // Tenta via bridge Android (sem necessidade de conexão)
        if (window.Android && Android.getLocalIp) {
            var localIp = Android.getLocalIp();
            if (localIp && localIp !== '') {
                document.getElementById('ip-display').textContent = localIp;
                document.getElementById('ping-display').textContent = 'local';
            }
        }

        // ── Carrega operadoras imediatamente via bridge síncrono ───────────────
        if (window.Android && Android.getOperators) {
            try {
                var json = Android.getOperators();
                if (json && json !== '[]') {
                    var ops = JSON.parse(json);
                    if (ops.length > 0) onOperatorsReady(ops, selectedOpName || ops[0].name);
                }
            } catch(e) {}
        }

        if (window.Android && Android.checkUpdates) Android.checkUpdates();
    });

    // =============================================================================
    // IP local — callback do Kotlin (chamado no onPageFinished)
    // =============================================================================
    window.onLocalIp = function(ip) {
        if (!isConnected && ip) {
            document.getElementById('ip-display').textContent = ip;
            document.getElementById('ping-display').textContent = 'local';
        }
    };

    // =============================================================================
    // Credenciais SSH
    // =============================================================================
    function hasSshCreds() {
        var u = storageGet('ssh_username'), p = storageGet('ssh_password');
        return !!(u && u.trim() && p && p.trim());
    }
    function updateSshCredBtn() {
        var btn = document.getElementById('ssh-cred-btn');
        if (hasSshCreds()) btn.classList.add('has-creds');
        else btn.classList.remove('has-creds');
    }
    function openSshPopup(editMode, uuid, opName) {
        sshPopupMode = editMode ? 'edit' : 'connect';
        sshPendingUuid = uuid || null; sshPendingOperator = opName || null;
        var su = storageGet('ssh_username') || '', sp = storageGet('ssh_password') || '';
        document.getElementById('ssh-username').value = su;
        document.getElementById('ssh-password').value = sp;
        if (editMode) {
            document.getElementById('ssh-popup-title').textContent = 'CREDENCIAIS SSH';
            document.getElementById('ssh-popup-sub').textContent = 'Edite suas credenciais de acesso SSH.';
            document.getElementById('ssh-cancel-btn').textContent = 'FECHAR';
            document.querySelector('.ssh-btn-confirm').textContent = 'SALVAR';
        } else {
            document.getElementById('ssh-popup-title').textContent = 'ACESSO SSH NECESSÁRIO';
            document.getElementById('ssh-popup-sub').textContent = 'Insira suas credenciais para conectar via SSH.\nSerão salvas para uso futuro.';
            document.getElementById('ssh-cancel-btn').textContent = 'CANCELAR';
            document.querySelector('.ssh-btn-confirm').textContent = 'SALVAR E CONECTAR';
        }
        document.getElementById('ssh-saved-badge').style.display = hasSshCreds() ? 'flex' : 'none';
        document.getElementById('ssh-error-msg').classList.remove('show');
        document.getElementById('ssh-popup-overlay').classList.add('open');
        setTimeout(function() { if (!su) document.getElementById('ssh-username').focus(); else if (!sp) document.getElementById('ssh-password').focus(); }, 300);
    }
    function closeSshPopup() {
        document.getElementById('ssh-popup-overlay').classList.remove('open');
        document.getElementById('ssh-password').type = 'password';
        document.getElementById('pwd-toggle-btn').textContent = '👁';
    }
    function cancelSshPopup() {
        closeSshPopup();
        if (sshPopupMode === 'connect') resetConnectionBtn();
        sshPendingUuid = null; sshPendingOperator = null;
    }
    function handleSshOverlayClick(e) {
        if (sshPopupMode === 'connect') return;
        if (e.target === document.getElementById('ssh-popup-overlay')) closeSshPopup();
    }
    function togglePwd() {
        var f = document.getElementById('ssh-password'), b = document.getElementById('pwd-toggle-btn');
        if (f.type === 'password') { f.type = 'text'; b.textContent = '🙈'; }
        else { f.type = 'password'; b.textContent = '👁'; }
    }
    function confirmSshCredentials() {
        var user = document.getElementById('ssh-username').value.trim();
        var pass = document.getElementById('ssh-password').value.trim();
        var err  = document.getElementById('ssh-error-msg');
        if (!user || !pass) { err.textContent = 'Usuário e senha são obrigatórios.'; err.classList.add('show'); return; }
        err.classList.remove('show');
        storageSave('ssh_username', user); storageSave('ssh_password', pass);
        updateSshCredBtn(); closeSshPopup();
        if (sshPopupMode === 'connect' && sshPendingUuid && sshPendingOperator) {
            var u = sshPendingUuid, o = sshPendingOperator;
            sshPendingUuid = null; sshPendingOperator = null;
            if (window.Android && Android.startSshWithCredentials) Android.startSshWithCredentials(u, o, user, pass);
        }
    }
    window.requestSshCredentials = function(uuid, opName, authFailed) {
        if (authFailed) {
            storageSave('ssh_username', ''); storageSave('ssh_password', '');
            updateSshCredBtn();
            document.getElementById('ssh-popup-sub').textContent = '⚠️ Credenciais incorretas. Tente novamente.';
        }
        openSshPopup(false, uuid, opName);
    };

    // =============================================================================
    // Operadoras
    // =============================================================================
    window.onOperatorsReady = function(operators, defaultOpName) {
        allOperators = operators || [];
        var targetName = selectedOpName || defaultOpName || (allOperators.length > 0 ? allOperators[0].name : null);
        if (targetName) {
            var op = allOperators.find(function(o){ return o.name === targetName; });
            if (op) { selectedOpName = op.name; applySelectedOperator(op); storageSave('netsmon_operator', op.name); }
        }
        renderModal();
    };
    function openOperatorModal() { renderModal(); document.getElementById('operator-modal').classList.add('open'); }
    function closeOperatorModal() { document.getElementById('operator-modal').classList.remove('open'); }
    function handleModalBackdrop(e) { if (e.target === document.getElementById('operator-modal')) closeOperatorModal(); }
    function renderModal() {
        if (allOperators.length === 0) return;
        var cats = [];
        allOperators.forEach(function(op){ if (op.category && op.category.name && cats.indexOf(op.category.name) < 0) cats.push(op.category.name); });
        cats.sort();
        if (!currentCategory || cats.indexOf(currentCategory) < 0) currentCategory = cats[0];
        var tabsEl = document.getElementById('cat-tabs'); tabsEl.innerHTML = '';
        cats.forEach(function(cat){
            var btn = document.createElement('button');
            btn.className = 'cat-tab' + (cat === currentCategory ? ' active' : '');
            btn.textContent = cat; btn.onclick = function(){ selectCategory(cat); };
            tabsEl.appendChild(btn);
        });
        renderOpList();
    }
    function selectCategory(cat) {
        currentCategory = cat;
        document.querySelectorAll('.cat-tab').forEach(function(t){ t.classList.toggle('active', t.textContent === cat); });
        renderOpList();
    }
    function renderOpList() {
        var list = document.getElementById('op-list');
        var filtered = allOperators.filter(function(op){ return op.category && op.category.name === currentCategory; });
        if (filtered.length === 0) { list.innerHTML = '<div style="text-align:center;padding:24px;color:#333;font-size:.8rem">Nenhuma configuração disponível</div>'; return; }
        list.innerHTML = '';
        filtered.forEach(function(op){
            var item = document.createElement('div');
            item.className = 'op-item' + (op.name === selectedOpName ? ' selected' : '');
            item.onclick = function(){ chooseOperator(op); };
            var badge = getBadge(op.mode);
            var iconSrc = op.icon || 'file:///android_asset/operadora.png';
            var desc = op.description ? '<div class="op-desc">' + escHtml(op.description) + '</div>' : '';
            item.innerHTML = '<img class="op-icon" src="' + iconSrc + '" onerror="this.src=\'file:///android_asset/operadora.png\'">' +
                '<div class="op-info"><div class="op-name">' + escHtml(op.name) + '</div>' + desc + '</div>' +
                '<span class="op-mode-badge ' + badge.cls + '">' + badge.label + '</span>' +
                '<div class="op-check"></div>';
            list.appendChild(item);
        });
    }
    function getBadge(mode) {
        switch((mode||'').toUpperCase()) {
            case 'SSH_DIRECT': return {cls:'badge-ssh',   label:'SSH'};
            case 'V2RAY':      return {cls:'badge-v2ray', label:'V2RAY'};
            case 'SSL_PROXY':  return {cls:'badge-ssl',   label:'SSL'};
            default:           return {cls:'badge-other', label:mode||'?'};
        }
    }
    function escHtml(s){ return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function chooseOperator(op) {
        selectedOpName = op.name; storageSave('netsmon_operator', op.name);
        if (window.Android && Android.selectOperator) Android.selectOperator(op.name);
        applySelectedOperator(op); closeOperatorModal();
    }
    function applySelectedOperator(op) {
        var img = document.getElementById('op-circle-img');
        if (img && op.icon) { img.src = op.icon; img.onerror = function(){ this.src='file:///android_asset/operadora.png'; }; }
        var label = document.getElementById('op-selected-label');
        if (label) label.textContent = op.name.toUpperCase();
        renderOpList();
    }

    // =============================================================================
    // Toast
    // =============================================================================
    var toastShown = false, toastTimer = null;
    window.onUpdateComplete = function() {
        if (toastShown) return; toastShown = true;
        var t = document.getElementById('update-toast'); t.classList.add('show');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(function(){ t.classList.remove('show'); }, 3000);
    };

    // =============================================================================
    // Background — carrega a imagem de forma lazy para não bloquear o neon
    // A imagem fica em z-index:2 com opacity:0.5, o neon em z-index:1 continua
    // visível através da imagem semi-transparente.
    // =============================================================================
    function applyBackground(url) {
        var bg  = document.getElementById('bg-layer');
        var old = document.getElementById('bg-video'); if (old) old.remove();
        bg.classList.remove('loaded');

        if (!url || !url.trim()) { bg.style.backgroundImage = 'none'; return; }
        url = url.trim();

        if (/\.(mp4|webm|ogg)(\?.*)?$/i.test(url)) {
            bg.style.backgroundImage = 'none';
            var v = document.createElement('video');
            v.id = 'bg-video'; v.src = url; v.autoplay = true; v.loop = true; v.muted = true; v.playsInline = true;
            v.style.cssText = 'position:fixed;inset:0;z-index:2;width:100%;height:100%;object-fit:cover;opacity:0;pointer-events:none;transition:opacity 0.8s';
            document.body.insertBefore(v, document.body.firstChild);
            v.oncanplay = function() { v.style.opacity = '0.5'; };
        } else {
            // Carrega imagem de forma assíncrona para não bloquear o render inicial
            var img = new Image();
            img.onload = function() {
                bg.style.backgroundImage = "url('" + url + "')";
                bg.classList.add('loaded');  // dispara transição para opacity:0.5
            };
            img.onerror = function() {
                // Se falhar, mantém o neon no fundo preto — sem mensagem de erro
                bg.style.backgroundImage = 'none';
            };
            img.src = url;
        }
    }

    // =============================================================================
    // Cronômetro
    // =============================================================================
    function startTimer() {
        connectTime = Date.now();
        timerInterval = setInterval(function(){
            var e=Math.floor((Date.now()-connectTime)/1000);
            var h=Math.floor(e/3600),m=Math.floor((e%3600)/60),s=e%60;
            document.getElementById('timer-display').textContent=pad(h)+':'+pad(m)+':'+pad(s);
        }, 1000);
    }
    function stopTimer(){ clearInterval(timerInterval); timerInterval=null; connectTime=null; document.getElementById('timer-display').textContent='--:--:--'; }
    function pad(n){ return n<10?'0'+n:''+n; }

    // =============================================================================
    // IP / Ping
    // =============================================================================
    function requestPing() {
        if (!isConnected) return;
        document.getElementById('ping-display').textContent = 'medindo...';
        document.getElementById('ip-display').textContent   = 'buscando...';
        if (window.Android && Android.measurePingNow) Android.measurePingNow();
        clearTimeout(pingFallbackTimer);
        pingFallbackTimer = setTimeout(function(){
            if (document.getElementById('ping-display').textContent === 'medindo...') fetchIpFallback();
        }, 5000);
    }

    // Fallback JS para IP público quando Android não conseguir
    function fetchIpFallback() {
        var t0 = Date.now();
        var apis = ['https://api64.ipify.org?format=json', 'https://ipinfo.io/json'];
        var i = 0;
        function tryNext() {
            if (i >= apis.length) {
                document.getElementById('ip-display').textContent   = 'sem acesso';
                document.getElementById('ping-display').textContent = '-- ms';
                return;
            }
            fetch(apis[i++], {cache:'no-store'})
                .then(function(r){ return r.json(); })
                .then(function(d){
                    var ip = d && d.ip ? d.ip : null;
                    document.getElementById('ip-display').textContent   = ip || 'indisponível';
                    document.getElementById('ping-display').textContent = ip ? (Date.now()-t0)+' ms' : '-- ms';
                })
                .catch(tryNext);
        }
        tryNext();
    }

    window.onSshStatus = function(message) {
        var sl = document.getElementById('status-label');
        if (sl && isConnected) { sl.innerText = message; sl.classList.remove('error-text'); sl.classList.add('connected'); }
    };

    window.onPingResult = function(ping, ip) {
        clearTimeout(pingFallbackTimer);
        document.getElementById('ping-display').textContent = ping < 0 ? 'timeout' : ping + ' ms';
        if (ip && ip !== '') document.getElementById('ip-display').textContent = ip;
    };

    // =============================================================================
    // Estado do túnel
    // =============================================================================
    function resetConnectionBtn() {
        var btn=document.getElementById('btn-connection'), sl=document.getElementById('status-label');
        btn.disabled=false; btn.innerText='LIGAR'; btn.classList.remove('active');
        sl.innerText=''; sl.classList.remove('connected','error-text');
        document.getElementById('ping-display').textContent='-- ms';
        document.getElementById('ip-display').textContent='--';
    }

    window.onTunnelState = function(state) {
        var btn=document.getElementById('btn-connection'), sl=document.getElementById('status-label');
        btn.disabled = false;

        if (state.error) {
            isConnected=false; stopTimer(); clearTimeout(pingFallbackTimer);
            btn.innerText='LIGAR'; btn.classList.remove('active');
            sl.classList.remove('connected'); sl.classList.add('error-text');
            document.getElementById('ping-display').textContent='-- ms';
            document.getElementById('ip-display').textContent='--';

            if (state.error === 'ssh_auth_failed') {
                sl.innerText = 'CREDENCIAIS INVÁLIDAS';
                window.requestSshCredentials(document.getElementById('user-uuid').value.trim(), selectedOpName, true); return;
            }
            if (state.error === 'ssh_no_credentials') {
                sl.innerText = 'CREDENCIAIS SSH NECESSÁRIAS';
                window.requestSshCredentials(document.getElementById('user-uuid').value.trim(), selectedOpName, false); return;
            }

            var msgs = {
                import_failed:'CONFIG INVÁLIDO', xray_start_failed:'FALHA AO INICIAR XRAY',
                permission_denied:'PERMISSÃO NEGADA', exception:'ERRO INTERNO',
                ssh_error:'ERRO SSH', ssh_payload_error:'ERRO NO HANDSHAKE',
                ssl_not_implemented:'SSL PROXY EM BREVE', no_operator_selected:'SELECIONE UMA OPERADORA',
                unknown_mode:'MODO DESCONHECIDO'
            };
            var errKey = state.error.startsWith('ssh_error:') ? 'SSH: '+state.error.split(':').slice(1).join(':') : null;
            sl.innerText = errKey || msgs[state.error] || 'ERRO';
            if (state.error === 'import_failed') alert('Não foi possível importar o config. Verifique o JSON.');
            return;
        }

        sl.classList.remove('error-text');
        if (state.running) {
            isConnected=true; startTimer();
            btn.innerText='PARAR'; btn.classList.add('active');
            sl.innerText='CONECTADO'; sl.classList.add('connected');
            requestPing();
        } else {
            isConnected=false; stopTimer(); clearTimeout(pingFallbackTimer);
            btn.innerText='LIGAR'; btn.classList.remove('active');
            sl.innerText=''; sl.classList.remove('connected');
            document.getElementById('ping-display').textContent='-- ms';
            // Ao desconectar, volta para IP local
            if (window.Android && Android.getLocalIp) {
                var localIp = Android.getLocalIp();
                document.getElementById('ip-display').textContent = localIp || '--';
                if (localIp) document.getElementById('ping-display').textContent = 'local';
            } else {
                document.getElementById('ip-display').textContent = '--';
            }
        }
    };

    // =============================================================================
    // Botão ligar / desligar
    // =============================================================================
    document.getElementById('btn-connection').onclick = function() {
        var btn=document.getElementById('btn-connection'), sl=document.getElementById('status-label');
        var uuid=document.getElementById('user-uuid').value.trim();
        if (!uuid) { alert('Insira sua CHAVE DE ACESSO (UUID)!'); return; }
        if (!uuidPattern.test(uuid)) { alert('UUID inválido.\nFormato: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'); return; }
        storageSave('netsmon_uuid', uuid);

        if (btn.innerText === 'LIGAR') {
            if (!selectedOpName && window.Android) { if (!confirm('Nenhuma operadora selecionada. Usar configuração padrão?')) return; }
            var op = allOperators.find(function(o){ return o.name === selectedOpName; });
            if (op && (op.mode === 'SSH_DIRECT' || op.mode === 'SLOWDNS') && !hasSshCreds()) { openSshPopup(false, uuid, selectedOpName); return; }
            btn.disabled=true; sl.innerText='CONECTANDO...'; sl.classList.add('connected'); sl.classList.remove('error-text');
            document.getElementById('ping-display').textContent='aguarde...';
            if (window.Android) {
                var sshUser = storageGet('ssh_username') || '', sshPass = storageGet('ssh_password') || '';
                Android.startTunnelWithCreds(uuid, sshUser, sshPass);
            } else { setTimeout(function(){ window.onTunnelState({running:true,error:null}); }, 1200); }
        } else {
            btn.disabled=true;
            if (window.Android) Android.stopTunnel();
            else window.onTunnelState({running:false,error:null});
        }
    };

    // =============================================================================
    // LOG AMIGÁVEL — estilo HTTP Injector
    // Exibe: badge de nível, timestamp curto, tag, mensagem
    // Resumo no topo: contadores de E/W/I e status de conexão
    // =============================================================================
    function openLogModal() { document.getElementById('log-modal').classList.add('open'); refreshLog(); }
    function closeLogModal() { document.getElementById('log-modal').classList.remove('open'); }

    // Regex para parsear linha do logcat no formato "time" (-v time):
    // "MM-DD HH:MM:SS.mmm PID-TID LEVEL/TAG: message"
    var LOG_RE = /^(\d{2}-\d{2}\s[\d:.]+)\s+\d+-\d+\s+([VDIWEF])\/([\S]+)\s*:\s*(.*)$/;
    // Regex alternativo sem PID-TID
    var LOG_RE2 = /^(\d{2}-\d{2}\s[\d:.]+)\s+([VDIWEF])\/([\S]+)\s*:\s*(.*)$/;

    function parseLogLine(line) {
        var m = LOG_RE.exec(line) || LOG_RE2.exec(line);
        if (!m) return null;
        return { time: m[1].split(' ')[1] || m[1], level: m[2], tag: m[3], msg: m[4] };
    }

    function buildLogEntry(p) {
        var entry = document.createElement('div');
        entry.className = 'log-entry lvl-' + p.level;

        var badge = document.createElement('span');
        badge.className = 'log-badge badge-' + p.level;
        badge.textContent = p.level;

        var meta = document.createElement('span');
        meta.className = 'log-meta';
        // Mostra apenas HH:MM:SS (sem milissegundos para economizar espaço)
        meta.textContent = p.time.split('.')[0];

        var tag = document.createElement('span');
        tag.className = 'log-tag';
        // Simplifica tags comuns para nomes legíveis
        var tagMap = {
            'WebUiActivity': 'App', 'GoLog': 'Xray', 'SshManager': 'SSH',
            'V2RayServiceManager': 'V2Ray', 'OperatorManager': 'Ops',
            'UpdateManager': 'Update', 'AngConfigManager': 'Config'
        };
        tag.textContent = tagMap[p.tag] || p.tag.replace('com.v2ray.ang.', '').replace('com.v2ray.ang', '').substring(0, 14);
        tag.title = p.tag;

        var msg = document.createElement('span');
        msg.className = 'log-msg';
        // Simplifica mensagens comuns para texto legível
        var text = p.msg
            .replace(/java\.lang\.\w+Exception:/g, 'Erro:')
            .replace(/at com\.v2ray\.ang\.[^\s]+/g, '')
            .replace(/at android\.[^\s]+/g, '')
            .replace(/at kotlin\.[^\s]+/g, '')
            .replace(/at kotlinx\.[^\s]+/g, '')
            .replace(/\t/g, '')
            .trim();
        msg.textContent = text || p.msg;

        entry.appendChild(badge); entry.appendChild(meta);
        entry.appendChild(tag);   entry.appendChild(msg);
        return entry;
    }

    function refreshLog() {
        var el  = document.getElementById('log-content');
        var sum = document.getElementById('log-summary');
        el.innerHTML = '<div style="color:#3a4a5a;padding:12px;font-size:.65rem">Carregando...</div>';

        setTimeout(function() {
            var raw = '';
            try {
                raw = (window.Android && Android.getAppLog) ? Android.getAppLog(400) : 'Android bridge não disponível.';
            } catch(e) { raw = 'Erro ao ler log: ' + e.message; }

            el.innerHTML = '';
            var lines = raw.split('\n');
            var counts = { E:0, W:0, I:0, D:0, V:0 };
            var connEvents = [];

            lines.forEach(function(line) {
                if (!line.trim()) return;
                var p = parseLogLine(line);
                if (p) {
                    counts[p.level] = (counts[p.level] || 0) + 1;
                    // Captura eventos de conexão para o resumo
                    if (p.level === 'I' && (p.msg.indexOf('iniciado') >= 0 || p.msg.indexOf('Xray') >= 0 || p.msg.indexOf('started') >= 0)) {
                        connEvents.push(p.time.split('.')[0] + ' ' + p.msg.substring(0, 40));
                    }
                    el.appendChild(buildLogEntry(p));
                } else {
                    // Linha sem formato reconhecido (stack trace, etc.) — exibe de forma discreta
                    if (line.trim().startsWith('at ') || line.trim().startsWith('java.') || line.trim().startsWith('kotlin.')) return; // oculta stack traces
                    var div = document.createElement('div');
                    div.style.cssText = 'padding:2px 10px;color:#2a3a4a;font-size:.58rem;word-break:break-all;';
                    div.textContent = line;
                    el.appendChild(div);
                }
            });

            // Atualiza resumo
            document.getElementById('sum-e').textContent = counts.E + (counts.E === 1 ? ' erro' : ' erros');
            document.getElementById('sum-w').textContent = counts.W + (counts.W === 1 ? ' aviso' : ' avisos');
            document.getElementById('sum-i').textContent = counts.I + ' info';
            var lastConn = connEvents.length > 0 ? connEvents[connEvents.length - 1].substring(0, 35) : 'Sem conexão';
            document.getElementById('sum-conn').textContent = lastConn;
            sum.style.display = 'flex';

            el.scrollTop = el.scrollHeight;
        }, 50);
    }

    // =============================================================================
    // Navegação
    // =============================================================================
    function goToConfig() { window.history.pushState({page:'config'},'Config'); showPage('config-screen'); }
    function goBack() { window.history.back(); }
    window.onpopstate = function() { showPage('home'); };
    function showPage(id) { document.querySelectorAll('section').forEach(function(s){ s.classList.remove('active'); }); document.getElementById(id).classList.add('active'); }

    // =============================================================================
    // Salvar config avançado
    // =============================================================================
    function saveConfig() {
        var val = document.getElementById('config-input').value.trim();
        if (val && !val.startsWith('vless://') && !val.includes('"outbounds"')) { alert('Config não reconhecido.\nUse VLESS ou JSON com "outbounds".'); return; }
        storageSave('netsmon_config', val);
        var gif = document.getElementById('gif-url-input').value.trim();
        storageSave('netsmon_bg', gif); applyBackground(gif);
        alert('Configurações salvas!'); goBack();
    }
</script>
